{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "packages/api/Dockerfile",
    "watchPatterns": [
      "packages/api/**/*",
      "packages/data/**/*",
      "packages/canonical/**/*",
      "packages/utilities/**/*"
    ]
  },
  "deploy": {
    "startCommand": "bun run packages/api/src/index.ts",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "healthcheckPath": "/api/v1/health",
    "healthcheckTimeout": 30
  },
  "env": {
    "PORT": {
      "default": "3000"
    },
    "NODE_ENV": {
      "default": "production"
    },
    "MW_USERNAME": {
      "required": true
    },
    "MW_PASSWORD": {
      "required": true
    },
    "MW_HOST": {
      "required": true
    },
    "MW_COMPANY": {
      "required": true
    }
  }
}