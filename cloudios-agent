  private async applyProfile(profileName: string) {
    try {
      info(`Applying profile: ${profileName}`);
      
      // Fetch profile from server
      const response = await fetch(`${this.config.server}/api/templates/${profileName}`);
      if (!response.ok) {
        throw new Error(`Profile not found: ${profileName}`);
      }
      
      const template: Template = await response.json();
      
      // Apply template files
      for (const [filePath, content] of Object.entries(template.files)) {
        const fullPath = path.join(process.cwd(), filePath);
        await fs.mkdir(path.dirname(fullPath), { recursive: true });
        await fs.writeFile(fullPath, content);
        console.log(`  Created: ${filePath}`);
      }
      
      // Merge settings
      if (template.settings) {
        await this.mergeSettings(template.settings, template.prefix);
      }
      
      success(`Profile ${profileName} applied successfully!`);
    } catch (error: any) {
      error(`Failed to apply profile: ${error.message}`);
      process.exit(1);
    }
  }

  private async removeProfile(prefix: string) {
    try {
      info(`Removing profile with prefix: ${prefix}`);
      
      const claudeDir = path.join(process.cwd(), '.claude');
      const dirsToCheck = ['commands', 'hooks', 'scripts', 'notes', 'plans'];
      
      let removedCount = 0;
      
      for (const dir of dirsToCheck) {
        const dirPath = path.join(claudeDir, dir);
        try {
          const entries = await fs.readdir(dirPath, { withFileTypes: true });
          
          for (const entry of entries) {
            if (entry.name.startsWith(prefix)) {
              const fullPath = path.join(dirPath, entry.name);
              
              if (entry.isDirectory()) {
                await fs.rm(fullPath, { recursive: true });
              } else {
                await fs.unlink(fullPath);
              }
              
              console.log(`  Removed: ${path.join(dir, entry.name)}`);
              removedCount++;
            }
          }
        } catch {
          // Directory doesn't exist, skip
        }
      }
      
      if (removedCount > 0) {
        success(`Removed ${removedCount} items with prefix '${prefix}'`);
      } else {
        warn(`No items found with prefix '${prefix}'`);
      }
    } catch (error: any) {
      error(`Failed to remove profile: ${error.message}`);
      process.exit(1);
    }
  }

  private async mergeSettings(templateSettings: any, prefix: string) {
    const settingsPath = path.join(process.cwd(), '.claude', 'settings.json');
    let currentSettings: any = {};
    
    try {
      const content = await fs.readFile(settingsPath, 'utf-8');
      currentSettings = JSON.parse(content);
    } catch {
      // No existing settings
    }
    
    // Deep merge settings
    const mergedSettings = this.deepMerge(currentSettings, templateSettings);
    
    await fs.writeFile(settingsPath, JSON.stringify(mergedSettings, null, 2));
    console.log(`  Updated: .claude/settings.json`);
  }

  private deepMerge(target: any, source: any): any {
    const result = { ...target };
    
    for (const key in source) {
      if (source[key] && typeof source[key] === 'object' && !Array.isArray(source[key])) {
        result[key] = this.deepMerge(result[key] || {}, source[key]);
      } else {
        result[key] = source[key];
      }
    }
    
    return result;
  }

