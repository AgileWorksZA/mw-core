// Main entry point
async function main() {
  // Auto-detect if we should run setup based on no arguments and no JARVIS setup
  if (process.argv.length <= 2 && !await new CloudiosAgent(config).isJarvisSetup()) {
    config.mode = 'setup';
  }
  
  const agent = new CloudiosAgent(config);
  await agent.run();
}

main().catch((error) => {
  error(`Fatal error: ${error.message}`);
  process.exit(1);
});