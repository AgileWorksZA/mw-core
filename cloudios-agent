  private async runProfileMode() {
    console.log(`${colors.bright}${colors.cyan}
╔═══════════════════════════════════════╗
║       CLOUDIOS PROFILE MANAGER        ║
║        Template Profile System        ║
╚═══════════════════════════════════════╝
${colors.reset}`);

    switch (this.config.profileAction) {
