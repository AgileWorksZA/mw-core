interface AudioPlayer {
  play(filePath: string, volume?: number): Promise<void>;
  stop(): void;
  isPlaying(): boolean;
}

class MacOSAudioPlayer implements AudioPlayer {
  private currentProcess: any = null;

  async play(filePath: string, volume: number = 1.0): Promise<void> {
    if (!existsSync(filePath)) {
      throw new Error(`Audio file not found: ${filePath}`);
    }

    return new Promise((resolve, reject) => {
      this.stop();

      if (volume < 1.0) {
        const volumePercent = Math.round(volume * 100);
        spawn("osascript", ["-e", `set volume output volume ${volumePercent}`]);
      }

      this.currentProcess = spawn("afplay", [filePath]);

      this.currentProcess.on("close", (code: number) => {
        this.currentProcess = null;
        if (code === 0) {
          resolve();
        } else {
          reject(new Error(`afplay exited with code ${code}`));
        }
      });

      this.currentProcess.on("error", (error: Error) => {
        this.currentProcess = null;
        reject(error);
      });
    });
  }

  stop(): void {
    if (this.currentProcess) {
      this.currentProcess.kill();
      this.currentProcess = null;
    }
  }

  isPlaying(): boolean {
    return this.currentProcess !== null;
  }
}

class LinuxAudioPlayer implements AudioPlayer {
  private currentProcess: any = null;

  async play(filePath: string, volume: number = 1.0): Promise<void> {
    if (!existsSync(filePath)) {
      throw new Error(`Audio file not found: ${filePath}`);
    }

    return new Promise((resolve, reject) => {
      this.stop();

      const players = [
        { cmd: "ffplay", args: ["-nodisp", "-autoexit", "-volume", String(Math.round(volume * 100)), filePath] },
        { cmd: "mpg123", args: ["-q", filePath] },
        { cmd: "aplay", args: [filePath] },
      ];

      const tryPlayer = (index: number) => {
        if (index >= players.length) {
          reject(new Error("No audio player found. Install ffplay, mpg123, or aplay."));
          return;
        }

        const { cmd, args } = players[index];
        this.currentProcess = spawn(cmd, args);

        this.currentProcess.on("close", (code: number) => {
          this.currentProcess = null;
          if (code === 0) {
            resolve();
          } else {
            tryPlayer(index + 1);
          }
        });

        this.currentProcess.on("error", () => {
          this.currentProcess = null;
          tryPlayer(index + 1);
        });
      };

      tryPlayer(0);
    });
  }

  stop(): void {
    if (this.currentProcess) {
      this.currentProcess.kill();
      this.currentProcess = null;
    }
  }

  isPlaying(): boolean {
    return this.currentProcess !== null;
  }
}

class WindowsAudioPlayer implements AudioPlayer {
  private currentProcess: any = null;

  async play(filePath: string, volume: number = 1.0): Promise<void> {
    if (!existsSync(filePath)) {
      throw new Error(`Audio file not found: ${filePath}`);
    }

    return new Promise((resolve, reject) => {
      this.stop();

      const script = `
        Add-Type -AssemblyName System.Media
        $player = New-Object System.Media.SoundPlayer
        $player.SoundLocation = "${filePath.replace(/\\/g, "\\\\")}"
        $player.PlaySync()
      `;

      this.currentProcess = spawn("powershell", ["-Command", script]);

      this.currentProcess.on("close", (code: number) => {
        this.currentProcess = null;
        if (code === 0) {
          resolve();
        } else {
          reject(new Error(`PowerShell exited with code ${code}`));
        }
      });

      this.currentProcess.on("error", (error: Error) => {
        this.currentProcess = null;
        reject(error);
      });
    });
  }

  stop(): void {
    if (this.currentProcess) {
      this.currentProcess.kill();
      this.currentProcess = null;
    }
  }

  isPlaying(): boolean {
    return this.currentProcess !== null;
  }
}

function createAudioPlayer(): AudioPlayer {
  const osType = platform();
  
  switch (osType) {
    case "darwin":
      return new MacOSAudioPlayer();
    case "linux":
      return new LinuxAudioPlayer();
    case "win32":
      return new WindowsAudioPlayer();
    default:
      throw new Error(`Unsupported platform: ${osType}`);
  }
}

class AudioQueue {
  private player: AudioPlayer;
  private queue: Array<{ path: string; volume?: number }> = [];
  private isProcessing = false;

  constructor() {
    this.player = createAudioPlayer();
  }

  async add(filePath: string, volume?: number): Promise<void> {
    this.queue.push({ path: filePath, volume });
    if (!this.isProcessing) {
      this.processQueue();
    }
  }

  private async processQueue(): Promise<void> {
    if (this.isProcessing || this.queue.length === 0) {
      return;
    }

    this.isProcessing = true;

    while (this.queue.length > 0) {
      const item = this.queue.shift()!;
      try {
        await this.player.play(item.path, item.volume);
      } catch (error) {
        console.error("Error playing audio:", error);
      }
    }

    this.isProcessing = false;
  }

  stop(): void {
    this.queue = [];
    this.player.stop();
    this.isProcessing = false;
  }

  get length(): number {
    return this.queue.length;
  }

  async playAudioFromURL(url: string, volume?: number): Promise<void> {
    try {
      const tempDir = os.tmpdir();
      const tempFile = path.join(tempDir, `jarvis-audio-${Date.now()}.wav`);
      
      const response = await fetch(url);
      if (!response.ok) {
        throw new Error(`Failed to download audio: ${response.status}`);
      }
      
      const buffer = await response.arrayBuffer();
      await fs.writeFile(tempFile, Buffer.from(buffer));
      
      await this.add(tempFile, volume);
      
      setTimeout(async () => {
        try {
          await fs.unlink(tempFile);
        } catch {
          // Ignore cleanup errors
        }
      }, 5000);
    } catch (error) {
      console.error("Error playing audio from URL:", error);
    }
  }
}

