  private async runAudioMode() {
    console.log(`${colors.bright}${colors.cyan}
╔═══════════════════════════════════════╗
║       CLOUDIOS AUDIO STREAMING        ║
║        Real-time Audio Playback       ║
╚═══════════════════════════════════════╝
${colors.reset}`);
    
    if (!this.config.mute) {
      this.audioQueue = new AudioQueue();
    }

    await this.checkForUpdates();
    
    const displayFilters = () => {
      const filters: string[] = [];
      if (this.config.projects.length > 0) {
        filters.push(`Projects: ${this.config.projects.join(", ")}`);
      }
      if (this.config.agents.length > 0) {
        filters.push(`Agents: ${this.config.agents.join(", ")}`);
      }
      if (this.config.mute) {
        filters.push("Audio: MUTED");
      }
      if (this.config.volume !== 1.0) {
        filters.push(`Volume: ${Math.round(this.config.volume * 100)}%`);
      }
      
      if (filters.length > 0) {
        console.log(`\n${colors.yellow}Active Filters:${colors.reset}`);
        filters.forEach(f => console.log(`  • ${f}`));
      }
    };

    displayFilters();
    
    this.connect();
    
    const updateStats = () => {
      const runtime = Math.floor((Date.now() - this.stats.startTime) / 1000);
      const status = this.stats.connected 
        ? `${colors.green}● Connected${colors.reset}` 
        : `${colors.red}● Disconnected${colors.reset}`;
      
      process.stdout.write(
        `\r${status} | Played: ${this.stats.audioPlayed} | Filtered: ${this.stats.audioFiltered} | Errors: ${this.stats.errors} | Runtime: ${runtime}s | Queue: ${this.audioQueue?.length || 0}`
      );
    };

    setInterval(updateStats, 1000);
    
    // Handle graceful shutdown
    const shutdown = async () => {
      console.log('\nShutting down...');
      
      // Send disconnect signal
      try {
        await fetch(`${this.config.server}/api/cloudios-agent/disconnect`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            project: path.basename(process.cwd()),
            timestamp: new Date().toISOString()
          })
        });
      } catch (error) {
        // Ignore errors during shutdown
      }
      
      if (this.eventSource) {
        this.eventSource.close();
      }
      if (this.reconnectTimeout) {
        clearTimeout(this.reconnectTimeout);
      }
      if (this.heartbeatInterval) {
        clearInterval(this.heartbeatInterval);
      }
      process.exit(0);
    };
    
    process.on('SIGINT', shutdown);
    process.on('SIGTERM', shutdown);
  }

  private connect() {
    const projectName = path.basename(process.cwd());
    const url = `${this.config.server}/api/audio.sse?project=${encodeURIComponent(projectName)}`;
    log(`\n🔗 Connecting to: ${url}`, colors.cyan);
    
    this.eventSource = new EventSource(url);
    
    this.eventSource.onopen = () => {
      this.stats.connected = true;
      console.log(`\n${colors.green}✅ Connected to JARVIS audio stream${colors.reset}`);
      
      // Start heartbeat
      this.startHeartbeat();
    };
    
    this.eventSource.onmessage = async (event) => {
      try {
        const data = JSON.parse(event.data);
        
        if (data.type === "audio_ready" && data.message) {
          const shouldPlay = this.shouldPlayAudio(data.message);
          
          if (shouldPlay) {
            await this.playAudio(data.message);
            this.stats.audioPlayed++;
          } else {
            this.stats.audioFiltered++;
          }
        }
      } catch (error) {
        console.error("\nError processing message:", error);
        this.stats.errors++;
      }
    };
    
    this.eventSource.onerror = (error) => {
      this.stats.connected = false;
      console.log(`\n${colors.red}❌ Connection error. Reconnecting in 5 seconds...${colors.reset}`);
      
      // Stop heartbeat
      if (this.heartbeatInterval) {
        clearInterval(this.heartbeatInterval);
        this.heartbeatInterval = undefined;
      }
      
      if (this.reconnectTimeout) {
        clearTimeout(this.reconnectTimeout);
      }
      
      this.reconnectTimeout = setTimeout(() => {
        this.connect();
      }, 5000);
    };
  }

  private startHeartbeat() {
    const projectName = path.basename(process.cwd());
    
    // Clear any existing heartbeat
    if (this.heartbeatInterval) {
      clearInterval(this.heartbeatInterval);
    }
    
    // Send heartbeat every 30 seconds
    this.heartbeatInterval = setInterval(async () => {
      try {
        await fetch(`${this.config.server}/api/cloudios-agent/heartbeat`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            project: projectName,
            timestamp: new Date().toISOString(),
            stats: {
              audioPlayed: this.stats.audioPlayed,
              audioFiltered: this.stats.audioFiltered,
              connected: this.stats.connected
            }
          })
        });
      } catch (error) {
        // Ignore heartbeat errors
      }
    }, 30000);
  }

  private shouldPlayAudio(message: any): boolean {
    // Check project filter
    if (this.config.projects.length > 0) {
      const projectName = message.repo_name || message.project_name || '';
      if (!this.config.projects.some(p => 
        projectName.toLowerCase().includes(p.toLowerCase())
      )) {
        return false;
      }
    }
    
    // Check agent filter
    if (this.config.agents.length > 0) {
      const agentName = message.agent_name || '';
      if (!this.config.agents.some(a => 
        agentName.toLowerCase().includes(a.toLowerCase())
      )) {
        return false;
      }
    }
    
    return true;
  }

  private async playAudio(message: any): Promise<void> {
    if (this.config.mute || !this.audioQueue) {
      return;
    }

    const audioUrl = `${this.config.server}${message.audio_url}`;
    
    // Check for voice override
    const agentRole = message.agent_role || 'default';
    const overrideVoice = this.config.voiceOverrides[agentRole];
    
    if (overrideVoice && message.voice !== overrideVoice) {
      console.log(`\n${colors.yellow}Voice override: ${agentRole} → ${overrideVoice}${colors.reset}`);
    }
    
    try {
      await this.audioQueue.playAudioFromURL(audioUrl, this.config.volume);
    } catch (error) {
      console.error("\nError playing audio:", error);
      this.stats.errors++;
    }
  }

  private async checkForUpdates(): Promise<boolean> {
    try {
      const response = await fetch(`${this.config.server}/api/version`);
      if (response.ok) {
        const data = await response.json();
        this.version = data.version;
        
        const localVersion = await this.getLocalVersion();
        if (localVersion && localVersion !== this.version) {
          console.log(`\n${colors.yellow}⚠️  Update available: ${localVersion} → ${this.version}${colors.reset}`);
          console.log(`   Run: cloudios-agent --sync`);
          return true;
        }
      }
    } catch (error) {
      // Ignore version check errors
    }
    return false;
  }

  private async getLocalVersion(): Promise<string | null> {
    try {
      const packagePath = path.join(process.cwd(), '.claude', 'version');
      const version = await fs.readFile(packagePath, 'utf-8');
      return version.trim();
    } catch {
      return null;
    }
  }

