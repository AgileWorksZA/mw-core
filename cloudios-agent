function parseVoiceOverrides(overrides?: string): Record<string, string> {
  if (!overrides) return {};
  
  const map: Record<string, string> = {};
  const pairs = overrides.split(",");
  
  for (const pair of pairs) {
    const [role, voice] = pair.split("=").map(s => s.trim());
    if (role && voice) {
      map[role] = voice;
    }
  }
  
  return map;
}

