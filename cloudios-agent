    );

    if (!hasPreExecute) {
      settings.hooks.PreExecute.push(preExecuteHookEntry);
    }

    if (!hasPostExecute) {
      settings.hooks.PostExecute.push(postExecuteHookEntry);
    }

    if (!hasPostTool) {
      settings.hooks.PostToolUse.push(postToolHookEntry);
    }

    if (!hasStop) {
      settings.hooks.Stop.push(stopHookEntry);
    }

    if (!hasNotification) {
      settings.hooks.Notification.push(notificationHookEntry);
    }

    await fs.writeFile(".claude/settings.json", JSON.stringify(settings, null, 2));

    // Check if .env exists and add JARVIS_SERVER if not already present
    try {
      const envPath = ".env";
      let envContent = "";
      
      try {
        envContent = await fs.readFile(envPath, "utf-8");
      } catch {
        // .env doesn't exist, that's okay
      }
      
      // Check if JARVIS_SERVER is already defined
      if (!envContent.includes("JARVIS_SERVER=")) {
        const envAddition = `\n# JARVIS Server Configuration\nJARVIS_SERVER=${config.server}\n`;
        
        if (envContent.length > 0 && !envContent.endsWith('\n')) {
          envContent += '\n';
        }
        
        envContent += envAddition;
        
        await fs.writeFile(envPath, envContent);
        info("Added JARVIS_SERVER to .env file");
      } else {
        info("JARVIS_SERVER already defined in .env");
      }
    } catch (err) {
      // Silently ignore .env errors
    }
    
    success("JARVIS integration setup complete!");
  }

