# syntax = docker/dockerfile:1

# Use specific Bun version
ARG BUN_VERSION=1.2.15
FROM oven/bun:${BUN_VERSION}-slim as base

LABEL fly_launch_runtime="React"

# Set production environment
ENV NODE_ENV="production"

# Install packages for building
RUN apt-get update -qq && \
    apt-get install -y python3 build-essential pkg-config && \
    rm -rf /var/lib/apt/lists /var/cache/apt/archives

WORKDIR /app

# Copy all package.json files for dependency installation
FROM base as deps
COPY package.json bun.lockb ./
COPY packages/utilities/package.json ./packages/utilities/
COPY packages/canonical/package.json ./packages/canonical/
COPY packages/data/package.json ./packages/data/
COPY packages/web1/package.json ./packages/web1/

# Install ALL dependencies (including devDependencies for building)
RUN bun install --frozen-lockfile

# Build stage
FROM base as build
WORKDIR /app

# Copy installed dependencies
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/packages ./packages

# Copy all source code
COPY . .

# Build all dependencies using the production script
RUN chmod +x scripts/build-for-production.sh && \
    ./scripts/build-for-production.sh

# Build web1
WORKDIR /app/packages/web1
RUN bun run build

# Production stage
FROM base as production

WORKDIR /app

# Copy only what's needed for production
COPY --from=build /app/packages/web1/build ./build
COPY --from=build /app/packages/web1/package.json ./package.json

# Install only production dependencies for serving
RUN bun add @react-router/serve

EXPOSE 3000

CMD ["bun", "run", "start"]