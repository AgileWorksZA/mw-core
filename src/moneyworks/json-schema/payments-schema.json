{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Payments",
  "description": "Payments table schema (file_num: 11) - Links invoices to payment transactions",
  "type": "object",
  "properties": {
    "SequenceNumber": {
      "type": "integer",
      "description": "Unsigned long sequence number"
    },
    "LastModifiedTime": {
      "type": "string",
      "format": "date-time",
      "description": "Last modified timestamp"
    },
    "InvoiceID": {
      "type": "integer",
      "description": "Invoice sequence number (indexed)"
    },
    "CashTrans": {
      "type": "integer",
      "description": "Cash transaction sequence number (indexed)"
    },
    "Date": {
      "type": "string",
      "format": "date",
      "description": "Payment date"
    },
    "GSTCycle": {
      "type": "integer",
      "description": "GST cycle"
    },
    "Amount": {
      "type": "number",
      "description": "Payment amount"
    }
  },
  "required": [
    "SequenceNumber",
    "LastModifiedTime",
    "InvoiceID",
    "CashTrans",
    "Amount"
  ]
}
