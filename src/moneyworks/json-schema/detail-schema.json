{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Detail",
  "description": "Detail table schema (file_num: 6) - Transaction line items",
  "type": "object",
  "properties": {
    "SequenceNumber": {
      "type": "integer",
      "description": "Unsigned long sequence number"
    },
    "LastModifiedTime": {
      "type": "string",
      "format": "date-time",
      "description": "Last modified timestamp"
    },
    "ParentSeq": {
      "type": "integer",
      "description": "Parent transaction sequence number (indexed)"
    },
    "Sort": {
      "type": "integer",
      "description": "Sort order"
    },
    "Account": {
      "type": "string",
      "maxLength": 14,
      "description": "Account code (indexed)"
    },
    "Dept": {
      "type": "string",
      "maxLength": 6,
      "description": "Department code"
    },
    "PostedQty": {
      "type": "number",
      "description": "Posted quantity"
    },
    "TaxCode": {
      "type": "string",
      "maxLength": 6,
      "description": "Tax code"
    },
    "Gross": {
      "type": "number",
      "description": "Gross amount"
    },
    "Tax": {
      "type": "number",
      "description": "Tax amount"
    },
    "Debit": {
      "type": "number",
      "description": "Debit amount"
    },
    "Credit": {
      "type": "number",
      "description": "Credit amount"
    },
    "Description": {
      "type": "string",
      "maxLength": 1024,
      "description": "Line item description"
    },
    "StockQty": {
      "type": "number",
      "description": "Stock quantity"
    },
    "StockCode": {
      "type": "string",
      "maxLength": 32,
      "description": "Stock code (indexed)"
    },
    "CostPrice": {
      "type": "number",
      "description": "Cost price"
    },
    "UnitPrice": {
      "type": "number",
      "description": "Unit price"
    },
    "Statement": {
      "type": "integer",
      "description": "Statement reference (indexed)"
    },
    "JobCode": {
      "type": "string",
      "maxLength": 10,
      "description": "Job code (indexed)"
    },
    "SaleUnit": {
      "type": "string",
      "maxLength": 6,
      "description": "Sales unit"
    },
    "Discount": {
      "type": "number",
      "description": "Discount"
    },
    "Flags": {
      "type": "integer",
      "description": "Flags"
    },
    "OrderQty": {
      "type": "number",
      "description": "Order quantity"
    },
    "BackorderQty": {
      "type": "number",
      "description": "Backorder quantity"
    },
    "PrevShipQty": {
      "type": "number",
      "description": "Previously shipped quantity"
    },
    "BaseCurrencyNet": {
      "type": "number",
      "description": "Base currency net amount"
    },
    "SerialNumber": {
      "type": "string",
      "maxLength": 32,
      "description": "Serial number"
    },
    "Period": {
      "type": "integer",
      "description": "Period"
    },
    "TransactionType": {
      "type": "string",
      "maxLength": 1,
      "description": "Transaction type"
    },
    "SecurityLevel": {
      "type": "integer",
      "description": "Security level (indexed)"
    },
    "RevalueQty": {
      "type": "number",
      "description": "Revalue quantity"
    },
    "StockLocation": {
      "type": "string",
      "maxLength": 16,
      "description": "Stock location"
    },
    "OrderStatus": {
      "type": "boolean",
      "description": "Order status"
    },
    "ExpensedTax": {
      "type": "number",
      "description": "Expensed tax amount"
    },
    "Date": {
      "type": "string",
      "format": "date",
      "description": "Transaction date"
    },
    "MoreFlags": {
      "type": "integer",
      "description": "Additional flags"
    },
    "UserNum": {
      "type": "number",
      "description": "User number (mutable: freely, script-only)"
    },
    "UserText": {
      "type": "string",
      "maxLength": 256,
      "description": "User text (mutable: freely, script-only)"
    },
    "TaggedText": {
      "type": "string",
      "maxLength": 256,
      "description": "Tagged text (mutable: freely, script-only)"
    },
    "NonInvRcvdNotInvoicedQty": {
      "type": "number",
      "description": "Non-inventory received not invoiced quantity"
    },
    "Custom1": {
      "type": "string",
      "maxLength": 32,
      "description": "Custom field 1 (mutable: freely, script-only)"
    },
    "Custom2": {
      "type": "string",
      "maxLength": 32,
      "description": "Custom field 2 (mutable: freely, script-only)"
    },
    "OriginalUnitCost": {
      "type": "number",
      "description": "Original unit cost"
    }
  },
  "required": [
    "SequenceNumber",
    "LastModifiedTime",
    "ParentSeq",
    "Account"
  ]
}
