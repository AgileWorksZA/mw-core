    "BankAccountNumber": {
      "type": "string",
      "maxLength": 24,
      "description": "Bank account number (mutable: freely, script-only)"
    },
    "BalanceLimit": {
      "type": "number",
      "description": "Balance limit"
    },
    "ManualChequeNumber": {
      "type": "string",
      "maxLength": 12,
      "description": "Manual cheque number"
    },
    "PrintedChequeNumber": {
      "type": "string",
      "maxLength": 12,
      "description": "Printed cheque number"
    },
    "LastStatementImport": {
      "type": "string",
      "format": "date-time",
      "description": "Last statement import timestamp"
    },
    "Comments": {
      "type": "string",
      "maxLength": 1024,
      "description": "Comments (mutable: freely, script-only)"
    },
    "ManualChequeNumDigits": {
      "type": "integer",
      "description": "Number of digits in manual cheque number"
    },
    "PrintedChequeNumDigits": {
      "type": "integer",
      "description": "Number of digits in printed cheque number"
    },
    "UserNum": {
      "type": "number",
      "description": "User number (mutable: freely, script-only)"
    },
    "UserText": {
      "type": "string",
      "maxLength": 256,
      "description": "User text (mutable: freely, script-only)"
    },
    "TaggedText": {
      "type": "string",
      "maxLength": 256,
      "description": "Tagged text (mutable: freely, script-only)"
    },
    "FeedID": {
      "type": "string",
      "maxLength": 32,
      "description": "Feed ID (mutable: freely, script-only)"
    },
    "Cashflow": {
      "type": "string",
      "maxLength": 8,
      "description": "Cashflow (mutable: freely, script-only)"
    },
    "Cashforecast": {
      "type": "string",
      "maxLength": 32,
      "description": "Cash forecast (mutable: freely, script-only)"
    },
    "EBITDA": {
      "type": "string",
      "maxLength": 2,
      "description": "EBITDA (mutable: conditionally)"
    },
    "ImportFormat": {
      "type": "string",
      "maxLength": 10,
      "description": "Import format"
    }
