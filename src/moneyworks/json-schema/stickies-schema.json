{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stickies",
  "description": "Stickies table schema (file_num: 27) - Sticky notes attached to records",
  "type": "object",
  "properties": {
    "SequenceNumber": {
      "type": "integer",
      "description": "Unsigned long sequence number"
    },
    "LastModifiedTime": {
      "type": "string",
      "format": "date-time",
      "description": "Last modified timestamp"
    },
    "FileNum": {
      "type": "integer",
      "description": "File number (indexed)"
    },
    "Colour": {
      "type": "integer",
      "description": "Display color"
    },
    "User": {
      "type": "string",
      "maxLength": 4,
      "description": "User initials"
    },
    "OwnerSeq": {
      "type": "integer",
      "description": "Owner record sequence (indexed)"
    },
    "Message": {
      "type": "string",
      "maxLength": 256,
      "description": "Sticky note message"
    },
    "Flags": {
      "type": "integer",
      "description": "Flags"
    }
  },
  "required": [
    "SequenceNumber",
    "LastModifiedTime",
    "FileNum",
    "OwnerSeq",
    "Message"
  ]
}
