{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Login",
  "description": "Login table schema (file_num: 29) - User login information",
  "type": "object",
  "properties": {
    "SequenceNumber": {
      "type": "integer",
      "description": "Unsigned long sequence number"
    },
    "LastModifiedTime": {
      "type": "string",
      "format": "date-time",
      "description": "Last modified timestamp"
    },
    "Initials": {
      "type": "string",
      "maxLength": 4,
      "description": "User initials (indexed)"
    },
    "Name": {
      "type": "string",
      "maxLength": 32,
      "description": "User full name"
    },
    "Password": {
      "type": "string",
      "maxLength": 34,
      "description": "Encrypted password"
    },
    "SecurityLevel": {
      "type": "integer",
      "description": "Security level"
    },
    "Privileges": {
      "type": "string",
      "maxLength": 66,
      "description": "User privileges"
    },
    "Email": {
      "type": "string",
      "maxLength": 64,
      "description": "Email address"
    },
    "Flags": {
      "type": "integer",
      "description": "User flags"
    },
    "Category": {
      "type": "string",
      "maxLength": 32,
      "description": "User category (mutable: freely, script-only)"
    },
    "Role": {
      "type": "string",
      "maxLength": 4,
      "description": "User role"
    },
    "UserNum": {
      "type": "number",
      "description": "User number (mutable: freely, script-only)"
    },
    "UserText": {
      "type": "string",
      "maxLength": 256,
      "description": "User text (mutable: freely, script-only)"
    },
    "TaggedText": {
      "type": "string",
      "maxLength": 256,
      "description": "Tagged text (mutable: freely, script-only)"
    },
    "SettingsDonor": {
      "type": "string",
      "maxLength": 4,
      "description": "Settings donor (mutable: freely, script-only)"
    }
  },
  "required": [
    "SequenceNumber",
    "LastModifiedTime",
    "Initials",
    "Name"
  ]
}
