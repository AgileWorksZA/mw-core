{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Build",
  "description": "Build table schema (file_num: 17) - Product build components",
  "type": "object",
  "properties": {
    "SequenceNumber": {
      "type": "integer",
      "description": "Unsigned long sequence number"
    },
    "LastModifiedTime": {
      "type": "string",
      "format": "date-time",
      "description": "Last modified timestamp"
    },
    "ProductSeq": {
      "type": "integer",
      "description": "Parent product sequence number (indexed)"
    },
    "Order": {
      "type": "integer",
      "description": "Component order"
    },
    "Qty": {
      "type": "number",
      "description": "Component quantity"
    },
    "PartCode": {
      "type": "string",
      "maxLength": 32,
      "description": "Component part code"
    },
    "Flags": {
      "type": "integer",
      "description": "Flags"
    },
    "Memo": {
      "type": "string",
      "maxLength": 256,
      "description": "Memo (mutable: freely, script-only)"
    }
  },
  "required": [
    "SequenceNumber",
    "LastModifiedTime",
    "ProductSeq",
    "PartCode",
    "Qty"
  ]
}
