{
  "type": "object",
  "title": "Asset",
  "description": "Represents an individual fixed asset. Internal Name: Asset.",
  "properties": {
    "Code": {
      "type": "string",
      "maxLength": 19,
      "description": "A unique code for the asset."
    },
    "Description": {
      "type": "string",
      "maxLength": 63,
      "description": "The description of the asset."
    },
    "Category": {
      "type": "string",
      "maxLength": 7,
      "description": "The Asset Category code of the asset (links to AssetCat)."
    },
    "SerialNum": {
      "type": ["string", "null"],
      "maxLength": 31,
      "description": "A serial number for the asset."
    },
    "Qty": {
      "type": "number",
      "description": "The quantity of the asset (normally 1)."
    },
    "ExpectedLife": {
      "type": ["number", "null"],
      "minimum": 0,
      "description": "The expected life in years of the asset."
    },
    "Cost": {
      "type": "number",
      "description": "The cost (per unit) of the asset."
    },
    "AccumDepreciation": {
      "type": "number",
      "description": "The accumulated depreciation recorded against the asset."
    },
    "AcquisitionDate": {
      "type": "string",
      "format": "date",
      "description": "Date on which the asset was acquired."
    },
    "LastDepreciatedDate": {
      "type": ["string", "null"],
      "format": "date",
      "description": "Date on which the asset was last depreciated."
    },
    "AcquisitionSeq": {
      "type": ["integer", "null"],
      "description": "The sequence number of the purchase transaction for the asset."
    },
    "DisposalSeq": {
      "type": ["integer", "null"],
      "description": "The sequence number of the last disposal transaction for the asset."
    },
    "Location": {
      "type": ["string", "null"],
      "maxLength": 15,
      "description": "Where the asset is kept."
    },
    "Dept": {
      "type": ["string", "null"],
      "maxLength": 5,
      "description": "The asset department (must be a MoneyWorks Department code)."
    },
    "PrivateUsePercent": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 100,
      "description": "The percent of the asset used privately."
    },
    "Status": {
      "type": "string",
      "maxLength": 3,
      "enum": ["NEW", "ACT", "NDP", "OTH", "DSP"],
      "description": "Asset status: NEW=New, ACT=Active, NDP=Non-depreciable, OTH=Other, DSP=Disposed."
    },
    "LastModifiedBy": {
      "type": ["string", "null"],
      "maxLength": 3,
      "description": "User initials who last modified the asset record."
    },
    "LastRevaluedDate": {
      "type": ["string", "null"],
      "format": "date",
      "description": "Date of last revaluation (blank if none)."
    },
    "ExpectedResidualValue": {
      "type": ["number", "null"],
      "minimum": 0,
      "description": "Expected residual value."
    },
    "RevalSurplusImpairAmt": {
      "type": ["number", "null"],
      "description": "Total revalued amount (positive if surplus)."
    },
    "UserNum": {
      "type": ["number", "null"],
      "description": "Scriptable number storage."
    },
    "UserText": {
      "type": ["string", "null"],
      "maxLength": 255,
      "description": "Scriptable text storage."
    },
    "AccumDepnAdj": {
      "type": ["number", "null"],
      "description": "Total adjustments to accumulated depreciation due to revaluations."
    },
    "BookValue": {
      "type": "number",
      "description": "The current book value."
    },
    "DisposalDate": {
      "type": ["string", "null"],
      "format": "date",
      "description": "Date last disposed."
    },
    "GainLossOnDisposal": {
      "type": ["number", "null"],
      "description": "The gain or loss on asset disposal."
    },
    "Colour": {
      "type": ["integer", "null"],
      "minimum": 0,
      "maximum": 7,
      "description": "Colour index (0-7)."
    },
    "TaggedText": {
      "type": ["string", "null"],
      "maxLength": 255,
      "description": "Scriptable tag storage."
    },
    "Type": {
      "type": "string",
      "enum": ["SL", "DV"],
      "description": "Depreciation type: SL (Straight Line) or DV (Diminishing Value)."
    },
    "Rate": {
      "type": "number",
      "description": "Depreciation rate (%)."
    },
    "Comment": {
      "type": ["string", "null"],
      "maxLength": 255,
      "description": "Comments on asset."
    },
    "Custom1": {
      "type": ["string", "null"],
      "maxLength": 255,
      "description": "User defined"
    },
    "Custom2": {
      "type": ["string", "null"],
      "maxLength": 255,
      "description": "User defined"
    },
    "Custom3": {
      "type": ["string", "null"],
      "maxLength": 255,
      "description": "User defined"
    },
    "Custom4": {
      "type": ["string", "null"],
      "maxLength": 255,
      "description": "User defined"
    }
  },
  "required": [
    "Code",
    "Description",
    "Category",
    "Qty",
    "Cost",
    "AccumDepreciation",
    "AcquisitionDate",
    "BookValue",
    "Status",
    "Type",
    "Rate"
  ]
}
