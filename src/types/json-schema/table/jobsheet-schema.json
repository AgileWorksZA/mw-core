{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JobSheet",
  "description": "JobSheet table schema (file_num: 18) - Job time and resource tracking",
  "type": "object",
  "properties": {
    "SequenceNumber": {
      "type": "integer",
      "description": "Unsigned long sequence number"
    },
    "LastModifiedTime": {
      "type": "string",
      "format": "date-time",
      "description": "Last modified timestamp"
    },
    "Job": {
      "type": "string",
      "maxLength": 10,
      "description": "Job code (indexed)"
    },
    "Qty": {
      "type": "number",
      "description": "Quantity (mutable: conditionally)"
    },
    "Resource": {
      "type": "string",
      "maxLength": 32,
      "description": "Resource code (indexed)"
    },
    "Date": {
      "type": "string",
      "format": "date",
      "description": "Date (mutable: conditionally)"
    },
    "CostCentre": {
      "type": "string",
      "maxLength": 6,
      "description": "Cost center (mutable: conditionally)"
    },
    "Account": {
      "type": "string",
      "maxLength": 8,
      "description": "Account code"
    },
    "Period": {
      "type": "integer",
      "description": "Accounting period"
    },
    "Units": {
      "type": "string",
      "maxLength": 6,
      "description": "Unit of measure (mutable: conditionally)"
    },
    "CostPrice": {
      "type": "number",
      "description": "Cost price (mutable: conditionally)"
    },
    "SellPrice": {
      "type": "number",
      "description": "Selling price (mutable: conditionally)"
    },
    "Memo": {
      "type": "string",
      "maxLength": 1024,
      "description": "Memo (mutable: freely, script-only)"
    },
    "DestTransSeq": {
      "type": "integer",
      "description": "Destination transaction sequence (mutable: freely, script-only)"
    },
    "SourceTransSeq": {
      "type": "integer",
      "description": "Source transaction sequence (indexed)"
    },
    "DateEntered": {
      "type": "string",
      "format": "date",
      "description": "Date entered"
    },
    "Flags": {
      "type": "integer",
      "description": "Flags"
    },
    "Colour": {
      "type": "integer",
      "description": "Display color (mutable: conditionally)"
    },
    "Status": {
      "type": "string",
      "maxLength": 1,
      "description": "Status (indexed, mutable: conditionally)"
    },
    "Type": {
      "type": "string",
      "maxLength": 1,
      "description": "Type (mutable: freely, script-only)"
    },
    "Analysis": {
      "type": "string",
      "maxLength": 10,
      "description": "Analysis code (mutable: conditionally)"
    },
    "BillValue": {
      "type": "number",
      "description": "Billed value"
    },
    "ActivityCode": {
      "type": "string",
      "maxLength": 32,
      "description": "Activity code (mutable: conditionally)"
    },
    "Comments": {
      "type": "string",
      "maxLength": 256,
      "description": "Comments (mutable: freely, script-only)"
    },
    "Batch": {
      "type": "integer",
      "description": "Batch number"
    },
    "EnteredBy": {
      "type": "string",
      "maxLength": 4,
      "description": "Entered by user (indexed)"
    },
    "SerialNumber": {
      "type": "string",
      "maxLength": 32,
      "description": "Serial number"
    },
    "StockLocation": {
      "type": "string",
      "maxLength": 16,
      "description": "Stock location"
    },
    "UserNum": {
      "type": "number",
      "description": "User number (mutable: freely, script-only)"
    },
    "UserText": {
      "type": "string",
      "maxLength": 256,
      "description": "User text (mutable: freely, script-only)"
    },
    "TaggedText": {
      "type": "string",
      "maxLength": 256,
      "description": "Tagged text (mutable: freely, script-only)"
    },
    "TimeProcessed": {
      "type": "string",
      "format": "date-time",
      "description": "Time processed"
    }
  },
  "required": [
    "SequenceNumber",
    "LastModifiedTime",
    "Job",
    "Date"
  ]
}
