{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Filter",
  "description": "Filter table schema (file_num: 26) - Custom data filters",
  "type": "object",
  "properties": {
    "SequenceNumber": {
      "type": "integer",
      "description": "Unsigned long sequence number"
    },
    "LastModifiedTime": {
      "type": "string",
      "format": "date-time",
      "description": "Last modified timestamp"
    },
    "File": {
      "type": "integer",
      "description": "File number to filter"
    },
    "TabSet": {
      "type": "integer",
      "description": "Tab set number"
    },
    "Tab": {
      "type": "integer",
      "description": "Tab number"
    },
    "Type": {
      "type": "integer",
      "description": "Filter type"
    },
    "User": {
      "type": "string",
      "maxLength": 4,
      "description": "User initials"
    },
    "Name": {
      "type": "string",
      "maxLength": 32,
      "description": "Filter name"
    },
    "FilterFunction": {
      "type": "string",
      "maxLength": 256,
      "description": "Filter function"
    },
    "Order": {
      "type": "integer",
      "description": "Display order (mutable: freely, script-only)"
    }
  },
  "required": [
    "SequenceNumber",
    "LastModifiedTime",
    "File",
    "User",
    "Name"
  ]
}
