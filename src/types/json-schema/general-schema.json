{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "General",
  "description": "General table schema (file_num: 2) - Contains general system-wide information",
  "type": "object",
  "properties": {
    "SequenceNumber": {
      "type": "integer",
      "description": "Unsigned long sequence number"
    },
    "LastModifiedTime": {
      "type": "string",
      "format": "date-time",
      "description": "Last modified timestamp"
    },
    "Code": {
      "type": "string",
      "maxLength": 10,
      "description": "Code (indexed)"
    },
    "Description": {
      "type": "string",
      "maxLength": 32,
      "description": "Description"
    },
    "Date": {
      "type": "string",
      "format": "date",
      "description": "Reference date"
    },
    "Long": {
      "type": "integer",
      "description": "Long integer value"
    }
  },
  "required": [
    "SequenceNumber",
    "LastModifiedTime",
    "Code"
  ]
}
