{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Message",
  "description": "Message table schema (file_num: 9) - System messages and reminders",
  "type": "object",
  "properties": {
    "SequenceNumber": {
      "type": "integer",
      "description": "Unsigned long sequence number"
    },
    "LastModifiedTime": {
      "type": "string",
      "format": "date-time",
      "description": "Last modified timestamp"
    },
    "StartDate": {
      "type": "string",
      "format": "date",
      "description": "Start date (mutable: freely, script-only)"
    },
    "EndDate": {
      "type": "string",
      "format": "date",
      "description": "End date (mutable: freely, script-only)"
    },
    "NextDate": {
      "type": "string",
      "format": "date",
      "description": "Next date (indexed, mutable: freely, script-only)"
    },
    "Keep": {
      "type": "boolean",
      "description": "Keep flag"
    },
    "Ref": {
      "type": "integer",
      "description": "Reference value"
    },
    "LastDay": {
      "type": "integer",
      "description": "Last day flag"
    },
    "NDaily": {
      "type": "integer",
      "description": "Daily repetition count"
    },
    "NWeekly": {
      "type": "integer",
      "description": "Weekly repetition count"
    },
    "NMonthly": {
      "type": "integer",
      "description": "Monthly repetition count"
    },
    "Once": {
      "type": "integer",
      "description": "One-time flag"
    },
    "XTimes": {
      "type": "integer",
      "description": "Number of times to repeat"
    },
    "Forever": {
      "type": "integer",
      "description": "Permanent flag"
    },
    "Day": {
      "type": "integer",
      "description": "Day number"
    },
    "Type": {
      "type": "integer",
      "description": "Message type"
    },
    "DayOfWeek": {
      "type": "integer",
      "description": "Day of week"
    },
    "N": {
      "type": "integer",
      "description": "N value"
    },
    "X": {
      "type": "integer",
      "description": "X value"
    },
    "AvoidWeekends": {
      "type": "integer",
      "description": "Avoid weekends flag"
    },
    "Reverse": {
      "type": "integer",
      "description": "Reverse flag"
    },
    "kill_next_time": {
      "type": "integer",
      "description": "Kill next time flag"
    },
    "Message": {
      "type": "string",
      "maxLength": 256,
      "description": "Message text (mutable: freely, script-only)"
    },
    "User": {
      "type": "string",
      "maxLength": 4,
      "description": "User initials"
    },
    "UserNum": {
      "type": "number",
      "description": "User number (mutable: freely, script-only)"
    },
    "UserText": {
      "type": "string",
      "maxLength": 256,
      "description": "User text (mutable: freely, script-only)"
    },
    "TaggedText": {
      "type": "string",
      "maxLength": 256,
      "description": "Tagged text (mutable: freely, script-only)"
    }
  },
  "required": [
    "SequenceNumber",
    "LastModifiedTime",
    "Message"
  ]
}
