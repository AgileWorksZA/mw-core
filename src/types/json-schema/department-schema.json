{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Department",
  "description": "Department table schema (file_num: 3)",
  "type": "object",
  "properties": {
    "SequenceNumber": {
      "type": "integer",
      "description": "Unsigned long sequence number"
    },
    "LastModifiedTime": {
      "type": "string",
      "format": "date-time",
      "description": "Last modified timestamp"
    },
    "Code": {
      "type": "string",
      "maxLength": 6,
      "description": "Department code (indexed)"
    },
    "Description": {
      "type": "string",
      "maxLength": 36,
      "description": "Department description (mutable: freely, script-only)"
    },
    "Classification": {
      "type": "string",
      "maxLength": 6,
      "description": "Classification code"
    },
    "Custom1": {
      "type": "string",
      "maxLength": 16,
      "description": "Custom field 1 (mutable: freely, script-only)"
    },
    "Custom2": {
      "type": "string",
      "maxLength": 10,
      "description": "Custom field 2 (mutable: freely, script-only)"
    },
    "Flags": {
      "type": "integer",
      "description": "Flags"
    },
    "UserNum": {
      "type": "number",
      "description": "User number (mutable: freely, script-only)"
    },
    "UserText": {
      "type": "string",
      "maxLength": 256,
      "description": "User text (mutable: freely, script-only)"
    },
    "TaggedText": {
      "type": "string",
      "maxLength": 256,
      "description": "Tagged text (mutable: freely, script-only)"
    }
  },
  "required": [
    "SequenceNumber",
    "LastModifiedTime",
    "Code",
    "Description"
  ]
}
