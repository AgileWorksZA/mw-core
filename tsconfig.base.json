{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"lib": ["ES2022"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"types": ["bun-types"],
		"downlevelIteration": true,
		"baseUrl": ".",
		"paths": {
			"@moneyworks/api/*": ["packages/api/src/*"],
			"@moneyworks/mcp-server/*": ["packages/mcp-server/src/*"],
			"@moneyworks/utilities": ["packages/utilities/src/index.ts"],
			"@moneyworks/utilities/*": ["packages/utilities/src/*"],
			"@moneyworks/core": ["packages/core/src/index.ts"],
			"@moneyworks/core/*": ["packages/core/src/*"],
			"@moneyworks/semantic": ["packages/semantic/src/index.ts"],
			"@moneyworks/semantic/*": ["packages/semantic/src/*"]
		}
	}
}