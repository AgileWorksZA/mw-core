{
  "name": "@moneyworks/data",
  "version": "0.1.0",
  "description": "MoneyWorks data access layer - REST client and repositories",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client/index.ts",
      "import": "./src/client/index.ts"
    },
    "./client/types": {
      "types": "./src/client/types.ts",
      "import": "./src/client/types.ts"
    },
    "./client/moneyworks-rest-client": {
      "types": "./src/client/moneyworks-rest-client.ts",
      "import": "./src/client/moneyworks-rest-client.ts"
    },
    "./client/moneyworks-smart-client": {
      "types": "./src/client/moneyworks-smart-client.ts",
      "import": "./src/client/moneyworks-smart-client.ts"
    },
    "./config": {
      "types": "./src/config/index.ts",
      "import": "./src/config/index.ts"
    },
    "./config/types": {
      "types": "./src/config/types.ts",
      "import": "./src/config/types.ts"
    },
    "./repositories": {
      "types": "./src/repositories/index.ts",
