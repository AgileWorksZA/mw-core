      "types": "./src/parsers/xml/moneyworks-xml-parser.ts",
      "import": "./src/parsers/xml/moneyworks-xml-parser.ts"
    },
    "./parsers/moneyworks-field-mappings": {
      "types": "./src/parsers/moneyworks-field-mappings.ts",
      "import": "./src/parsers/moneyworks-field-mappings.ts"
    },
    "./parsers/smart-tsv-parser": {
      "types": "./src/parsers/smart-tsv-parser.ts",
      "import": "./src/parsers/smart-tsv-parser.ts"
    },
    "./parsers/date-parser": {
      "types": "./src/parsers/date-parser.ts",
      "import": "./src/parsers/date-parser.ts"
    },
    "./parsers/number-parser": {
      "types": "./src/parsers/number-parser.ts",
      "import": "./src/parsers/number-parser.ts"
    },
    "./parsers/data-parser": {
      "types": "./src/parsers/data-parser.ts",
      "import": "./src/parsers/data-parser.ts"
    },
    "./parsers/account-parser": {
      "types": "./src/parsers/account-parser.ts",
      "import": "./src/parsers/account-parser.ts"
    },
    "./parsers/enum-parser": {
      "types": "./src/parsers/enum-parser.ts",
      "import": "./src/parsers/enum-parser.ts"
    },
    "./parsers/string-parser": {
      "types": "./src/parsers/string-parser.ts",
      "import": "./src/parsers/string-parser.ts"
    },
    "./converters": {
      "types": "./src/converters/index.ts",
      "import": "./src/converters/index.ts"
    },
    "./converters/export-format-converter": {
      "types": "./src/converters/export-format-converter.ts",
      "import": "./src/converters/export-format-converter.ts"
    }
