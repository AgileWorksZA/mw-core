  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@moneyworks/canonical": "workspace:*",
    "@moneyworks/utilities": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "latest",
    "typescript": "^5.6.3"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "keywords": [
    "moneyworks",
    "data",
    "repository",
    "rest",
    "client"
  ],
  "author": "MoneyWorks Core Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/moneyworks/mw-core.git",
