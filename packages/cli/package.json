{
  "name": "@moneyworks/cli",
  "version": "0.1.0",
  "description": "CLI for testing MoneyWorks core functionality",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./commands": {
      "types": "./src/commands/index.ts",
      "import": "./src/commands/index.ts"
    },
    "./commands/*": {
      "types": "./src/commands/*.ts",
      "import": "./src/commands/*.ts"
    },
    "./config": {
      "types": "./src/config.ts",
      "import": "./src/config.ts"
    }
  },
  "bin": {
    "mw": "./dist/index.js"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile mw",
    "build:dist": "bun build src/index.ts --outdir dist --target node"
  },
  "dependencies": {
    "@moneyworks/data": "workspace:*",
    "@moneyworks/canonical": "workspace:*",
    "@moneyworks/utilities": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}