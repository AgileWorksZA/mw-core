# MoneyWorks Connection Settings
MW_HOST=your-moneyworks-server.com
MW_USERNAME=your-username
MW_PASSWORD=your-password
MW_COMPANY=your-company-file

# Server Settings
PORT=3000
NODE_ENV=production

# Optional Settings
MW_PORT=6700
MW_PROTOCOL=https
MW_TIMEZONE=UTC

# Cache Settings (optional)
CACHE_TTL=300
CACHE_MAX_SIZE=100

# CORS Settings (optional)
CORS_ORIGIN=*
CORS_CREDENTIALS=true