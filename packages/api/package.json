{
  "name": "@moneyworks/api",
  "version": "0.1.0",
  "description": "MoneyWorks REST API with ElysiaJS",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts --port 3002",
    "start": "bun src/index.ts",
    "start:compiled": "bun dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "elysia": "^1.3.5",
    "@elysiajs/swagger": "^1.3.1",
    "@elysiajs/cors": "^1.3.3",
    "@moneyworks/data": "workspace:*",
    "@moneyworks/canonical": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.2.17",
    "typescript": "^5.8.3"
  },
  "keywords": [
    "moneyworks",
    "api",
    "rest",
    "elysia"
  ]
}