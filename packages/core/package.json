{
  "name": "@moneyworks/core",
  "version": "0.1.0",
  "description": "Core TypeScript library for MoneyWorks - types, interfaces, and shared models",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./types": {
      "bun": "./src/types/index.ts",
      "types": "./src/types/index.ts",
      "import": "./src/types/index.ts"
    },
    "./models": {
      "bun": "./src/models/index.ts",
      "types": "./src/models/index.ts",
      "import": "./src/models/index.ts"
    },
    "./utils": {
      "bun": "./src/utils/index.ts",
      "types": "./src/utils/index.ts",
      "import": "./src/utils/index.ts"
    },
    "./tables/*": {
      "bun": "./src/tables/*.ts",
      "types": "./src/tables/*.ts",
      "import": "./src/tables/*.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "latest",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "keywords": [
    "moneyworks",
    "core",
    "types",
    "typescript",
    "shared"
  ],
  "author": "MoneyWorks Team",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  }
}