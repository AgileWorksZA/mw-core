{
  "name": "@moneyworks/core",
  "version": "0.1.0",
  "description": "Core TypeScript library for MoneyWorks - types, interfaces, and shared models",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./types": {
      "bun": "./src/types/index.ts",
      "types": "./src/types/index.ts",
      "import": "./src/types/index.ts"
    },
    "./models": {
      "bun": "./src/models/index.ts",
      "types": "./src/models/index.ts",
      "import": "./src/models/index.ts"
    },
    "./utils": {
      "bun": "./src/utils/index.ts",
      "types": "./src/utils/index.ts",
      "import": "./src/utils/index.ts"
    },
    "./tables": {
      "bun": "./src/tables/index.ts",
      "types": "./src/tables/index.ts",
      "import": "./src/tables/index.ts"
    },
    "./tables/*": {
      "bun": "./src/tables/*.ts",
      "types": "./src/tables/*.ts",
      "import": "./src/tables/*.ts"
    },
    "./export-import": {
      "bun": "./src/export-import/index.ts",
      "types": "./src/export-import/index.ts",
      "import": "./src/export-import/index.ts"
    },
    "./rest": {
      "bun": "./src/rest/index.ts",
      "types": "./src/rest/index.ts",
      "import": "./src/rest/index.ts"
    },
    "./schemas/*.json": {
      "import": "./src/schemas/*.json"
    },
    "./schemas": {
      "bun": "./src/schemas/index.ts",
      "types": "./src/schemas/index.ts",
      "import": "./src/schemas/index.ts"
    }
  },
  "files": ["src", "README.md"],
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern='src/.*\\.test\\.ts$'",
    "test:integration": "TEST_TYPE=integration jest --testPathPattern='src/.*\\.integration\\.test\\.ts$'",
    "test:check-data": "bun run src/test-utils/check-test-data.ts",
    "typecheck": "tsc --noEmit",
    "generate:schemas": "bun run scripts/generate-schemas.ts",
    "example:export-import": "bun run examples/export-import-usage.ts"
  },
  "dependencies": {
    "@types/xml2js": "^0.4.14",
    "xml2js": "^0.6.2",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.22.3",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "latest",
    "typescript": "^5.5.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.1.2",
    "@jest/globals": "^29.7.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "keywords": ["moneyworks", "core", "types", "typescript", "shared"],
  "author": "MoneyWorks Team",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  }
}
