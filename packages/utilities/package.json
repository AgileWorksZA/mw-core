{
  "name": "@moneyworks/utilities",
  "version": "0.1.0",
  "description": "Shared utilities for MoneyWorks packages",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts",
      "require": "./src/*.ts"
    }
  },
  "scripts": {
    "test": "bun test",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "tsc -p tsconfig.dev.json --noEmit"
  },
  "keywords": [
    "moneyworks",
    "utilities",
    "date",
    "json",
    "helpers"
  ],
  "author": "MoneyWorks Team",
  "license": "MIT",
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "bun": "^1.0.0"
  }
}