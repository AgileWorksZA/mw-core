{
  "name": "@moneyworks/utilities",
  "version": "0.1.0",
  "description": "Shared utilities for MoneyWorks packages",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.js"
    }
  },
  "scripts": {
    "test": "bun test",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "tsc -p tsconfig.dev.json --noEmit"
  },
  "keywords": [
    "moneyworks",
    "utilities",
    "date",
    "json",
    "helpers"
  ],
  "author": "MoneyWorks Team",
  "license": "MIT",
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "bun": "^1.0.0"
  }
}