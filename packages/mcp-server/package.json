{
  "name": "@moneyworks/mcp-server",
  "version": "1.0.0",
  "description": "MCP server for MoneyWorks AI assistant with error tracking",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node",
    "start": "node dist/index.js",
    "db:migrate": "bun run src/database/migrate.ts",
    "db:reset": "rm -f data/tickets.db && bun run db:migrate"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@moneyworks/api": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/bun": "^1.1.13"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}