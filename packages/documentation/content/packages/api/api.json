              "value": "compact",
              "description": "Raw arrays for minimal overhead"
            },
            {
              "value": "compact-headers",
              "description": "Arrays with field names in first row"
            },
            {
              "value": "full",
              "description": "Complete objects with field names"
            },
            {
              "value": "schema",
              "description": "Objects with complete field metadata"
            }
