{
  "name": "@moneyworks/api",
  "version": "0.1.0",
  "description": "MoneyWorks REST API with ElysiaJS - High-performance, type-safe access to MoneyWorks data",
  "exports": [
    {
      "name": "Application Factory",
      "items": [
        {
          "name": "createApp",
          "type": "function",
          "description": "Create the MoneyWorks API application with Elysia",
          "signature": "function createApp(client: SmartMoneyWorksClient, config?: APIConfig): Elysia",
          "parameters": [
            {
              "name": "client",
              "type": "SmartMoneyWorksClient",
              "description": "MoneyWorks client instance from @moneyworks/data"
            },
            {
              "name": "config",
              "type": "APIConfig",
              "optional": true,
              "description": "API configuration options"
            }
          ],
          "returns": {
            "type": "Elysia",
            "description": "Configured Elysia application instance"
          },
          "usage": [
            "```typescript",
            "import { createApp } from '@moneyworks/api/app';",
            "import { createSmartClient } from '@moneyworks/data';",
            "",
            "const client = createSmartClient(config);",
            "const app = createApp(client, {",
            "  port: 3000,",
            "  enableSwagger: true,",
            "  enableCors: true",
            "});",
            "",
            "app.listen({ port: 3000 });",
            "```"
          ],
          "examples": [
            {
              "title": "Basic API server",
              "code": [
                "// Minimal setup",
                "const app = createApp(client);",
                "app.listen({ port: 3000 });"
              ]
            },
            {
              "title": "Production configuration",
              "code": [
                "const app = createApp(client, {",
                "  basePath: '/api/v1',",
                "  enableSwagger: false,",
                "  enableCors: true,",
                "  corsOrigins: ['https://app.example.com'],",
                "  enableCacheWarming: true",
                "});"
              ]
            }
          ]
        },
        {
          "name": "APIConfig",
          "type": "interface",
          "description": "Configuration options for the API application",
          "signature": "interface APIConfig",
          "properties": [
            {
              "name": "port",
              "type": "number",
              "optional": true,
              "description": "Port to listen on (default: from environment)"
            },
            {
              "name": "host",
              "type": "string",
              "optional": true,
              "description": "Host to bind to (default: '0.0.0.0')"
            },
            {
              "name": "basePath",
              "type": "string",
              "optional": true,
              "description": "Base path for API routes (default: '/api/v1')"
            },
            {
              "name": "enableSwagger",
              "type": "boolean",
              "optional": true,
              "description": "Enable Swagger documentation (default: true)"
            },
            {
              "name": "enableCors",
              "type": "boolean",
              "optional": true,
              "description": "Enable CORS support (default: true)"
            },
            {
              "name": "corsOrigins",
              "type": "string[]",
              "optional": true,
              "description": "Allowed CORS origins (default: ['*'])"
            },
            {
              "name": "enableCacheWarming",
              "type": "boolean",
              "optional": true,
              "description": "Warm up caches on startup (default: true)"
            }
          ]
        }
      ]
    },
    {
      "name": "Controllers",
      "items": [
        {
          "name": "BaseTableController",
          "type": "class",
          "description": "Base controller for MoneyWorks table operations",
          "signature": "abstract class BaseTableController",
          "usage": [
            "```typescript",
            "import { BaseTableController } from '@moneyworks/api/controllers/base-table';",
            "",
            "export class AccountController extends BaseTableController {",
            "  constructor(client: SmartMoneyWorksClient) {",
            "    super(client, 'Account');",
            "  }",
            "}",
            "```"
          ],
          "methods": [
            {
              "name": "export",
              "description": "Export table data with filtering and formatting",
              "signature": "async export(params: ExportParams): Promise<ExportResult>"
            },
            {
              "name": "getSchema",
              "description": "Get table schema with field metadata",
              "signature": "async getSchema(): Promise<TableSchema>"
            },
            {
              "name": "getLabels",
              "description": "Get localized field labels",
              "signature": "async getLabels(language: string): Promise<FieldLabels>"
            }
          ]
        },
        {
          "name": "TaxRateController",
          "type": "class",
          "description": "Controller for TaxRate table operations",
          "signature": "class TaxRateController extends BaseTableController",
          "usage": [
            "```typescript",
            "import { TaxRateController } from '@moneyworks/api/controllers/tax-rate';",
            "",
            "const controller = new TaxRateController(client);",
            "const taxRates = await controller.export({",
            "  format: 'full',",
            "  filter: 'Rate > 0'",
            "});",
            "```"
          ]
        },
        {
          "name": "CompanyController",
          "type": "class",
          "description": "Controller for company information operations",
          "signature": "class CompanyController",
          "methods": [
            {
              "name": "getInfo",
              "description": "Get company information",
              "signature": "async getInfo(fields?: string[]): Promise<CompanyInfo>"
            },
            {
              "name": "listFields",
              "description": "List available company fields",
              "signature": "async listFields(): Promise<CompanyField[]>"
            }
          ]
        },
        {
          "name": "LabelsController",
          "type": "class",
          "description": "Controller for field label operations",
          "signature": "class LabelsController",
          "methods": [
            {
              "name": "getLanguages",
              "description": "Get supported languages",
              "signature": "async getLanguages(): Promise<Language[]>"
            },
            {
              "name": "getTranslations",
              "description": "Get UI translations for a language",
              "signature": "async getTranslations(lang: string): Promise<Translations>"
            },
            {
              "name": "getAllLabels",
              "description": "Get all field labels for a language",
              "signature": "async getAllLabels(lang: string): Promise<AllLabels>"
            }
          ]
        }
      ]
    },
    {
      "name": "Middleware",
      "items": [
        {
          "name": "errorHandler",
          "type": "function",
          "description": "Global error handling middleware",
          "signature": "function errorHandler(): Elysia",
          "usage": [
            "```typescript",
            "import { errorHandler } from '@moneyworks/api/middleware/error-handler';",
            "",
            "app.use(errorHandler());",
            "```"
          ],
          "features": [
            "Consistent error format",
            "MoneyWorks error mapping",
            "Request ID tracking",
            "Stack trace in development"
          ]
        },
        {
          "name": "requestId",
          "type": "function",
          "description": "Request ID generation and tracking middleware",
          "signature": "function requestId(): Elysia",
          "usage": [
            "```typescript",
            "import { requestId } from '@moneyworks/api/middleware/request-id';",
            "",
            "app.use(requestId());",
            "// Adds context.requestId to all requests",
            "```"
          ]
        },
        {
          "name": "logging",
          "type": "function",
          "description": "Request/response logging middleware",
          "signature": "function logging(): Elysia",
          "features": [
            "Request method and path",
            "Response status and timing",
            "Error logging",
            "Structured log format"
          ]
        },
        {
          "name": "i18n",
          "type": "function",
          "description": "Internationalization middleware",
          "signature": "function i18n(): Elysia",
          "usage": [
            "```typescript",
            "import { i18n } from '@moneyworks/api/middleware/i18n';",
            "",
            "app.use(i18n());",
            "// Parses Accept-Language header",
            "// Adds context.language",
            "```"
          ]
        }
      ]
    },
    {
      "name": "Routes",
      "items": [
        {
          "name": "createTableRoutes",
          "type": "function",
          "description": "Create routes for table operations",
          "signature": "function createTableRoutes(registry: TableRegistry, client: SmartMoneyWorksClient, labelCache: TTLCache): Elysia",
          "endpoints": [
            {
              "method": "GET",
              "path": "/tables",
              "description": "List available tables"
            },
            {
              "method": "GET",
