          "endpoints": [
            {
              "method": "POST",
              "path": "/eval",
              "description": "Evaluate MWScript expression"
            },
            {
              "method": "POST",
              "path": "/eval/template/:table",
              "description": "Evaluate with table template"
            }
          ]
        },
        {
          "name": "createCompanyRoutes",
          "type": "function",
          "description": "Create routes for company operations",
          "signature": "function createCompanyRoutes(client: SmartMoneyWorksClient, cache: TTLCache): Elysia",
          "endpoints": [
            {
              "method": "GET",
              "path": "/company",
              "description": "Get company information"
            },
            {
              "method": "GET",
              "path": "/company/fields",
              "description": "List company fields"
            }
          ]
        },
        {
          "name": "createI18nRoutes",
          "type": "function",
          "description": "Create routes for internationalization",
          "signature": "function createI18nRoutes(client: SmartMoneyWorksClient, cache: TTLCache): Elysia",
          "endpoints": [
            {
              "method": "GET",
              "path": "/i18n/languages",
              "description": "List supported languages"
            },
            {
              "method": "GET",
              "path": "/i18n/translations/:lang",
              "description": "Get UI translations"
            },
            {
              "method": "GET",
              "path": "/i18n/labels/:lang",
              "description": "Get all field labels"
            }
          ]
        },
        {
          "name": "createHealthRoutes",
          "type": "function",
          "description": "Create routes for health checks",
          "signature": "function createHealthRoutes(client: SmartMoneyWorksClient): Elysia",
          "endpoints": [
            {
              "method": "GET",
              "path": "/health",
              "description": "Health check endpoint"
            }
          ]
        },
        {
          "name": "createVersionRoutes",
          "type": "function",
          "description": "Create routes for version information",
          "signature": "function createVersionRoutes(client: SmartMoneyWorksClient): Elysia",
          "endpoints": [
            {
              "method": "GET",
              "path": "/version",
              "description": "Get API and MoneyWorks version"
            }
          ]
        }
      ]
    },
    {
      "name": "Schemas",
      "items": [
        {
          "name": "ErrorSchema",
          "type": "schema",
          "description": "Standard error response schema",
          "signature": "const ErrorSchema: TObject",
          "structure": {
            "error": {
              "code": "string",
              "message": "string",
              "details": "any (optional)",
              "requestId": "string"
            }
          },
          "usage": [
            "```typescript",
            "import { ErrorSchema } from '@moneyworks/api/schemas/common';",
            "",
            "// Use in route definition",
            ".get('/endpoint', handler, {",
            "  response: {",
            "    400: ErrorSchema,",
            "    404: ErrorSchema",
            "  }",
            "})",
            "```"
          ]
        },
        {
          "name": "ExportFormatEnum",
          "type": "schema",
          "description": "Available export formats",
          "signature": "const ExportFormatEnum: TUnion",
          "values": ["compact", "compact-headers", "full", "schema"],
          "usage": [
            "```typescript",
            "import { ExportFormatEnum } from '@moneyworks/api/schemas/common';",
            "",
            "// Validate format parameter",
            "query: t.Object({",
            "  format: ExportFormatEnum",
            "})",
            "```"
          ]
        },
