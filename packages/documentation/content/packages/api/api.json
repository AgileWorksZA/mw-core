              "description": "Export table data"
            },
            {
              "method": "GET",
              "path": "/tables/:table/schema",
              "description": "Get table schema"
            },
            {
              "method": "GET",
              "path": "/tables/:table/labels",
              "description": "Get field labels"
            }
          ]
        },
        {
          "name": "createEvalRoutes",
