    {
      "name": "Services",
      "items": [
        {
          "name": "createCaches",
          "type": "function",
          "description": "Create cache instances for various data types",
          "signature": "function createCaches(): Caches",
          "returns": {
            "type": "Caches",
            "properties": [
              {
                "name": "labels",
                "type": "TTLCache<LabelData>",
                "description": "Cache for field labels"
              },
              {
                "name": "eval",
                "type": "TTLCache<EvalResult>",
                "description": "Cache for evaluation results"
              },
              {
                "name": "company",
                "type": "TTLCache<CompanyData>",
                "description": "Cache for company information"
              }
            ]
          },
          "usage": [
            "```typescript",
            "import { createCaches } from '@moneyworks/api/services/cache';",
            "",
            "const caches = createCaches();",
            "",
            "// Use in controllers",
            "const cached = await caches.labels.get(key);",
            "if (!cached) {",
            "  const data = await fetchLabels();",
            "  await caches.labels.set(key, data);",
            "}",
            "```"
          ]
        },
        {
          "name": "TTLCache",
          "type": "class",
          "description": "Time-to-live cache implementation",
          "signature": "class TTLCache<T>",
          "parameters": [
            {
              "name": "options",
              "type": "TTLCacheOptions",
              "properties": [
                {
                  "name": "ttl",
                  "type": "number",
                  "description": "Time to live in milliseconds"
                },
                {
                  "name": "maxSize",
                  "type": "number",
                  "description": "Maximum cache entries"
                }
              ]
            }
          ],
          "methods": [
            {
              "name": "get",
              "signature": "async get(key: string): Promise<T | null>"
            },
            {
              "name": "set",
              "signature": "async set(key: string, value: T): Promise<void>"
            },
            {
              "name": "delete",
              "signature": "async delete(key: string): Promise<void>"
            },
            {
              "name": "clear",
              "signature": "async clear(): Promise<void>"
            },
            {
              "name": "warmUp",
              "signature": "async warmUp(entries: WarmUpEntry[]): Promise<void>"
            }
          ]
        }
      ]
    },
    {
      "name": "Registry",
      "items": [
        {
          "name": "createTableRegistry",
          "type": "function",
          "description": "Create a registry of available table controllers",
          "signature": "function createTableRegistry(client: SmartMoneyWorksClient): TableRegistry",
          "usage": [
            "```typescript",
            "import { createTableRegistry } from '@moneyworks/api/registry/table-registry';",
            "",
            "const registry = createTableRegistry(client);",
            "",
            "// Check if table is available",
            "if (registry.has('Account')) {",
            "  const controller = registry.get('Account');",
            "  const data = await controller.export();",
            "}",
            "```"
          ]
        },
        {
          "name": "TableRegistry",
          "type": "class",
          "description": "Registry for table controllers",
          "signature": "class TableRegistry",
          "methods": [
            {
              "name": "register",
              "description": "Register a table controller",
              "signature": "register(table: string, controller: BaseTableController): void"
            },
            {
              "name": "get",
              "description": "Get a table controller",
              "signature": "get(table: string): BaseTableController | undefined"
            },
            {
              "name": "has",
              "description": "Check if table is registered",
              "signature": "has(table: string): boolean"
            },
            {
              "name": "list",
              "description": "List all registered tables",
              "signature": "list(): string[]"
            }
          ]
        }
      ]
