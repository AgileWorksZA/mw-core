    {
      "name": "Hooks",
      "items": [
        {
          "name": "useAuth",
          "type": "hook",
          "description": "Access authentication state and user information",
          "signature": "function useAuth(): AuthState",
          "returns": {
            "type": "AuthState",
            "properties": [
              {
                "name": "isLoaded",
                "type": "boolean",
                "description": "Whether auth state has loaded"
              },
              {
                "name": "isSignedIn",
                "type": "boolean",
                "description": "Whether user is authenticated"
              },
              {
                "name": "user",
                "type": "User | null",
                "description": "Current user object"
              },
              {
                "name": "signOut",
                "type": "() => Promise<void>",
                "description": "Sign out function"
              }
            ]
          },
          "usage": [
            "```typescript",
            "import { useAuth } from '~/hooks/use-auth';",
            "",
            "function UserProfile() {",
            "  const { isSignedIn, user, signOut } = useAuth();",
            "  ",
            "  if (!isSignedIn) {",
            "    return <Navigate to=\"/sign-in\" />;",
            "  }",
            "  ",
            "  return (",
            "    <div>",
            "      <p>Welcome, {user.firstName}!</p>",
            "      <Button onClick={signOut}>Sign Out</Button>",
            "    </div>",
            "  );",
            "}",
            "```"
          ]
        },
        {
          "name": "useMoneyWorks",
          "type": "hook",
          "description": "Access MoneyWorks client for current connection",
          "signature": "function useMoneyWorks(): MoneyWorksHookResult",
          "returns": {
            "type": "MoneyWorksHookResult",
            "properties": [
              {
                "name": "client",
                "type": "MoneyWorksRESTClient | null",
                "description": "Configured MoneyWorks client"
              },
              {
                "name": "currentConnection",
                "type": "Connection | null",
                "description": "Active connection details"
              }
            ]
          },
          "usage": [
            "```typescript",
            "import { useMoneyWorks } from '~/hooks/use-moneyworks';",
            "",
            "function TaxRatesList() {",
            "  const { client, currentConnection } = useMoneyWorks();",
            "  ",
            "  const { data, isLoading } = useQuery({",
            "    queryKey: ['taxRates', currentConnection?.id],",
            "    queryFn: () => client!.export('TaxRate'),",
            "    enabled: !!client",
            "  });",
            "  ",
            "  if (!currentConnection) {",
            "    return <NoConnectionMessage />;",
            "  }",
            "  ",
            "  return <TaxRatesTable data={data} />;",
            "}",
            "```"
          ]
        }
      ]
    },
