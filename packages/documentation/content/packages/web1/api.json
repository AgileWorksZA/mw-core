          "description": "Context provider for managing MoneyWorks connections",
          "signature": "function ConnectionProvider({ children }: ConnectionProviderProps): JSX.Element",
          "context": {
            "name": "ConnectionContext",
            "value": {
              "connections": "Connection[]",
              "currentConnection": "Connection | null",
              "currentConnectionId": "string | null",
              "switchConnection": "(id: string) => void",
              "createConnection": "(data: CreateConnectionData) => Promise<Connection>",
              "updateConnection": "(id: string, data: UpdateConnectionData) => Promise<Connection>",
              "deleteConnection": "(id: string) => Promise<void>",
              "refreshConnections": "() => Promise<void>"
            }
          },
          "usage": [
            "```typescript",
            "// In root.tsx",
            "<ConnectionProvider>",
            "  <App />",
            "</ConnectionProvider>",
            "",
            "// In components",
            "import { useConnection } from '~/contexts/connection-context';",
            "",
            "function MyComponent() {",
            "  const { currentConnection, switchConnection } = useConnection();",
            "  // Use connection data",
            "}",
            "```"
          ]
        }
      ]
