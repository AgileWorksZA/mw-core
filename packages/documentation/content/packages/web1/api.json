{
  "name": "@moneyworks/web1",
  "version": "0.1.0",
  "description": "Modern web application for MoneyWorks with React Router v7, React Query, and Radix UI",
  "exports": [
    {
      "name": "Components",
      "items": [
        {
          "name": "AddCompanyDialog",
          "type": "component",
          "description": "Modal dialog for adding new MoneyWorks connections",
          "signature": "function AddCompanyDialog(props: AddCompanyDialogProps): JSX.Element",
          "props": [
            {
              "name": "open",
              "type": "boolean",
              "description": "Control dialog visibility"
            },
            {
              "name": "onOpenChange",
              "type": "(open: boolean) => void",
              "description": "Callback when dialog state changes"
            },
            {
              "name": "onSuccess",
              "type": "(connection: Connection) => void",
              "optional": true,
              "description": "Callback after successful connection creation"
            }
          ],
          "usage": [
            "```typescript",
            "import { AddCompanyDialog } from '~/components/add-company-dialog';",
            "",
            "function MyComponent() {",
            "  const [open, setOpen] = useState(false);",
            "  ",
            "  return (",
            "    <AddCompanyDialog",
            "      open={open}",
            "      onOpenChange={setOpen}",
            "      onSuccess={(connection) => {",
            "        toast.success(`Connected to ${connection.name}`);",
            "      }}",
            "    />",
            "  );",
            "}",
            "```"
          ]
        },
        {
          "name": "AuthGuard",
