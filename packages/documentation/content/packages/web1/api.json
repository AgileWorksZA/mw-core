            {
              "name": "fallback",
              "type": "React.ReactNode",
              "optional": true,
              "description": "Content to show when not authenticated"
            },
            {
              "name": "redirectTo",
              "type": "string",
              "optional": true,
              "description": "URL to redirect to when not authenticated"
            }
          ],
          "usage": [
            "```typescript",
            "import { AuthGuard } from '~/components/auth-guard';",
            "",
            "<AuthGuard redirectTo=\"/sign-in\">",
            "  <ProtectedContent />",
            "</AuthGuard>",
            "```"
          ]
        },
