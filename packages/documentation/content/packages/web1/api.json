          "description": "Protect routes requiring authentication",
          "signature": "function AuthGuard({ children, fallback }: AuthGuardProps): JSX.Element",
          "props": [
            {
              "name": "children",
              "type": "React.ReactNode",
              "description": "Content to show when authenticated"
