{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist",
		"declaration": true,
		"declarationMap": true,
		"composite": true,
		"tsBuildInfoFile": "./tsconfig.tsbuildinfo",
		"noEmit": false,
		"allowImportingTsExtensions": false,
		"paths": {
			"@moneyworks/canonical": ["./src/index.ts"],
			"@moneyworks/canonical/*": ["./src/*"],
			"@moneyworks/utilities": ["../utilities/src/index.ts"],
			"@moneyworks/utilities/*": ["../utilities/src/*"]
		},
		"baseUrl": "."
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"],
	"references": [{ "path": "../utilities" }]
}
