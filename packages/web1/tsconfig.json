{
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/.server/**/*.ts",
    "**/.server/**/*.tsx",
    "**/.client/**/*.ts",
    "**/.client/**/*.tsx"
  ],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "isolatedModules": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "target": "ES2022",
    "strict": true,
    "allowJs": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["./app/*"],
      "@moneyworks/data": ["../data/src/index.ts"],
      "@moneyworks/data/*": ["../data/src/*"],
      "@moneyworks/canonical": ["../canonical/src/index.ts"],
      "@moneyworks/canonical/*": ["../canonical/src/*"],
      "@moneyworks/utilities": ["../utilities/src/index.ts"],
      "@moneyworks/utilities/*": ["../utilities/src/*"]
    }
  }
}