#!/usr/bin/env bun

import { parseArgs } from "util";
import { EventSource } from "eventsource";
import * as fs from "node:fs/promises";
import * as path from "node:path";
import { spawn } from "node:child_process";
import * as os from "node:os";
import { platform } from "os";
import { existsSync } from "fs";
import readline from "readline";

// Configuration
const DEFAULT_SERVER = process.env.CLOUDIOS_SERVER || "http://localhost:4000";

// ANSI escape codes
const ansi = {
  // Cursor control
  clearScreen: '\x1b[2J',
  clearLine: '\x1b[2K',
  moveCursor: (row: number, col: number) => `\x1b[${row};${col}H`,
  hideCursor: '\x1b[?25l',
  showCursor: '\x1b[?25h',
  saveCursor: '\x1b[s',
  restoreCursor: '\x1b[u',
  
  // Colors
  reset: '\x1b[0m',
  bright: '\x1b[1m',
  dim: '\x1b[2m',
  red: '\x1b[31m',
  green: '\x1b[32m',
  yellow: '\x1b[33m',
  blue: '\x1b[34m',
  magenta: '\x1b[35m',
  cyan: '\x1b[36m',
  white: '\x1b[37m',
  
  // Background colors
  bgRed: '\x1b[41m',
  bgGreen: '\x1b[42m',
  bgYellow: '\x1b[43m',
  bgBlue: '\x1b[44m',
  bgMagenta: '\x1b[45m',
  bgCyan: '\x1b[46m',
};

// Terminal UI Manager
class TerminalUI {
  private width: number = process.stdout.columns || 80;
  private height: number = process.stdout.rows || 24;
  private logs: string[] = [];
  private maxLogs = 10;
  public stats = {
    connected: false,
    audioPlayed: 0,
    audioFiltered: 0,
    errors: 0,
    startTime: Date.now(),
    lastHeartbeat: null as Date | null,
    queueSize: 0,
  };
  private currentProject: string;
  private server: string;
  
  constructor(project: string, server: string) {
    this.currentProject = project;
    this.server = server;
    
    // Handle terminal resize
    process.stdout.on('resize', () => {
      this.width = process.stdout.columns || 80;
      this.height = process.stdout.rows || 24;
      this.render();
    });
    
    // Hide cursor
    process.stdout.write(ansi.hideCursor);
  }
  
  cleanup() {
    process.stdout.write(ansi.showCursor);
    process.stdout.write(ansi.clearScreen);
    process.stdout.write(ansi.moveCursor(1, 1));
  }
  
  updateStats(stats: Partial<typeof this.stats>) {
    Object.assign(this.stats, stats);
    this.render();
  }
  
  addLog(message: string, type: 'info' | 'error' | 'success' | 'warning' = 'info') {
    const timestamp = new Date().toLocaleTimeString();
    const icons = {
      info: '●',
      error: '✕',
      success: '✓',
      warning: '⚠'
    };
    const colors = {
      info: ansi.cyan,
      error: ansi.red,
      success: ansi.green,
      warning: ansi.yellow
    };
    
    const log = `${ansi.dim}${timestamp}${ansi.reset} ${colors[type]}${icons[type]}${ansi.reset} ${message}`;
    this.logs.unshift(log);
    
    // Keep only the last N logs
    if (this.logs.length > this.maxLogs) {
      this.logs = this.logs.slice(0, this.maxLogs);
    }
    
    this.render();
  }
  
  render() {
    process.stdout.write(ansi.clearScreen);
    process.stdout.write(ansi.moveCursor(1, 1));
    
    // Header
    this.renderHeader();
    
    // Status bar
    this.renderStatusBar();
    
    // Stats
    this.renderStats();
    
    // Activity log
    this.renderActivityLog();
    
    // Footer
    this.renderFooter();
  }
  
  private renderHeader() {
    const title = "HERMES AUDIO STREAMING";
    const subtitle = "Real-time Audio Playback";
    const padding = Math.floor((this.width - title.length) / 2);
    
    // Box top
    process.stdout.write(ansi.cyan + '╔' + '═'.repeat(this.width - 2) + '╗\n');
    
    // Title
    process.stdout.write('║' + ' '.repeat(padding) + ansi.bright + title + ansi.reset + ansi.cyan);
    process.stdout.write(' '.repeat(this.width - padding - title.length - 2) + '║\n');
    
    // Subtitle
    const subPadding = Math.floor((this.width - subtitle.length) / 2);
    process.stdout.write('║' + ' '.repeat(subPadding) + ansi.dim + subtitle + ansi.reset + ansi.cyan);
    process.stdout.write(' '.repeat(this.width - subPadding - subtitle.length - 2) + '║\n');
    
    // Box bottom
    process.stdout.write('╚' + '═'.repeat(this.width - 2) + '╝' + ansi.reset + '\n\n');
  }
  
  private renderStatusBar() {
    const status = this.stats.connected 
      ? `${ansi.bgGreen}${ansi.white} CONNECTED ${ansi.reset}` 
      : `${ansi.bgRed}${ansi.white} DISCONNECTED ${ansi.reset}`;
    
    const project = `${ansi.bgBlue}${ansi.white} ${this.currentProject} ${ansi.reset}`;
    const server = `${ansi.dim}${this.server}${ansi.reset}`;
    
    process.stdout.write(`${status} ${project} ${server}\n\n`);
  }
  
  private renderStats() {
    const runtime = this.formatRuntime(Date.now() - this.stats.startTime);
    const lastHeartbeat = this.stats.lastHeartbeat 
      ? this.formatTimeSince(this.stats.lastHeartbeat) 
      : 'Never';
    
    // Stats grid
    const stats = [
      { label: 'Runtime', value: runtime, color: ansi.cyan },
      { label: 'Played', value: this.stats.audioPlayed.toString(), color: ansi.green },
      { label: 'Filtered', value: this.stats.audioFiltered.toString(), color: ansi.yellow },
      { label: 'Errors', value: this.stats.errors.toString(), color: ansi.red },
      { label: 'Queue', value: this.stats.queueSize.toString(), color: ansi.magenta },
      { label: 'Heartbeat', value: lastHeartbeat, color: ansi.blue },
    ];
    
    // Render in 2 rows of 3 columns
    const colWidth = Math.floor(this.width / 3);
    for (let row = 0; row < 2; row++) {
      let line = '';
      for (let col = 0; col < 3; col++) {
        const idx = row * 3 + col;
        if (idx < stats.length) {
          const stat = stats[idx];
          const content = `${stat.color}${stat.label}:${ansi.reset} ${ansi.bright}${stat.value}${ansi.reset}`;
          line += content.padEnd(colWidth, ' ');
        }
      }
      process.stdout.write(line + '\n');
    }
    process.stdout.write('\n');
  }
  
  private renderActivityLog() {
    const title = 'Activity Log';
    process.stdout.write(`${ansi.bright}${title}${ansi.reset}\n`);
    process.stdout.write('─'.repeat(this.width) + '\n');
    
    const availableLines = this.height - 15; // Reserve space for header, stats, footer
    const logsToShow = Math.min(this.logs.length, availableLines);
    
    for (let i = 0; i < logsToShow; i++) {
      process.stdout.write(this.logs[i] + '\n');
    }
    
    // Fill remaining space
    for (let i = logsToShow; i < availableLines; i++) {
      process.stdout.write('\n');
    }
  }
  
  private renderFooter() {
    const footer = `${ansi.dim}Press Ctrl+C to exit${ansi.reset}`;
    const padding = Math.floor((this.width - footer.length) / 2);
    process.stdout.write(ansi.moveCursor(this.height - 1, 1));
    process.stdout.write(' '.repeat(padding) + footer);
  }
  
  private formatRuntime(ms: number): string {
    const seconds = Math.floor(ms / 1000);
    const minutes = Math.floor(seconds / 60);
    const hours = Math.floor(minutes / 60);
    
    if (hours > 0) {
      return `${hours}h ${minutes % 60}m`;
    } else if (minutes > 0) {
      return `${minutes}m ${seconds % 60}s`;
    } else {
      return `${seconds}s`;
    }
  }
  
  private formatTimeSince(date: Date): string {
    const seconds = Math.floor((Date.now() - date.getTime()) / 1000);
    if (seconds < 60) {
      return `${seconds}s ago`;
    } else if (seconds < 3600) {
      return `${Math.floor(seconds / 60)}m ago`;
    } else {
      return `${Math.floor(seconds / 3600)}h ago`;
    }
  }
}

// Audio Player Classes (simplified from original)
interface AudioPlayer {
  play(filePath: string, volume?: number): Promise<void>;
  stop(): void;
  isPlaying(): boolean;
}

class MacOSAudioPlayer implements AudioPlayer {
  private currentProcess: any = null;

  async play(filePath: string, volume: number = 1.0): Promise<void> {
    if (!existsSync(filePath)) {
      throw new Error(`Audio file not found: ${filePath}`);
    }

    return new Promise((resolve, reject) => {
      this.stop();

      if (volume < 1.0) {
        const volumePercent = Math.round(volume * 100);
        spawn("osascript", ["-e", `set volume output volume ${volumePercent}`]);
      }

      this.currentProcess = spawn("afplay", [filePath]);

      this.currentProcess.on("close", (code: number) => {
        this.currentProcess = null;
        if (code === 0) {
          resolve();
        } else {
          reject(new Error(`afplay exited with code ${code}`));
        }
      });

      this.currentProcess.on("error", (error: Error) => {
        this.currentProcess = null;
        reject(error);
      });
    });
  }

  stop(): void {
    if (this.currentProcess) {
      this.currentProcess.kill();
      this.currentProcess = null;
    }
  }

  isPlaying(): boolean {
    return this.currentProcess !== null;
  }
}

// Linux Audio Player
class LinuxAudioPlayer implements AudioPlayer {
  private currentProcess: any = null;

  async play(filePath: string, volume: number = 1.0): Promise<void> {
    if (!existsSync(filePath)) {
      throw new Error(`Audio file not found: ${filePath}`);
    }

    return new Promise((resolve, reject) => {
      this.stop();

      const players = [
        { cmd: "ffplay", args: ["-nodisp", "-autoexit", "-volume", String(Math.round(volume * 100)), filePath] },
        { cmd: "mpg123", args: ["-q", filePath] },
        { cmd: "aplay", args: [filePath] },
      ];

      const tryPlayer = (index: number) => {
        if (index >= players.length) {
          reject(new Error("No audio player found. Install ffplay, mpg123, or aplay."));
          return;
        }

        const { cmd, args } = players[index];
        this.currentProcess = spawn(cmd, args);

        this.currentProcess.on("close", (code: number) => {
          this.currentProcess = null;
          if (code === 0) {
            resolve();
          } else {
            tryPlayer(index + 1);
          }
        });

        this.currentProcess.on("error", () => {
          this.currentProcess = null;
          tryPlayer(index + 1);
        });
      };

      tryPlayer(0);
    });
  }

  stop(): void {
    if (this.currentProcess) {
      this.currentProcess.kill();
      this.currentProcess = null;
    }
  }

  isPlaying(): boolean {
    return this.currentProcess !== null;
  }
}

// Windows Audio Player
class WindowsAudioPlayer implements AudioPlayer {
  private currentProcess: any = null;

  async play(filePath: string, volume: number = 1.0): Promise<void> {
    if (!existsSync(filePath)) {
      throw new Error(`Audio file not found: ${filePath}`);
    }

    return new Promise((resolve, reject) => {
      this.stop();

      const script = `
        Add-Type -AssemblyName System.Media
        $player = New-Object System.Media.SoundPlayer
        $player.SoundLocation = "${filePath.replace(/\\/g, "\\\\")}"
        $player.PlaySync()
      `;

      this.currentProcess = spawn("powershell", ["-Command", script]);

      this.currentProcess.on("close", (code: number) => {
        this.currentProcess = null;
        if (code === 0) {
          resolve();
        } else {
          reject(new Error(`PowerShell exited with code ${code}`));
        }
      });

      this.currentProcess.on("error", (error: Error) => {
        this.currentProcess = null;
        reject(error);
      });
    });
  }

  stop(): void {
    if (this.currentProcess) {
      this.currentProcess.kill();
      this.currentProcess = null;
    }
  }

  isPlaying(): boolean {
    return this.currentProcess !== null;
  }
}

// Factory function to create appropriate audio player
function createAudioPlayer(): AudioPlayer {
  const osType = platform();
  
  switch (osType) {
    case "darwin":
      return new MacOSAudioPlayer();
    case "linux":
      return new LinuxAudioPlayer();
    case "win32":
      return new WindowsAudioPlayer();
    default:
      throw new Error(`Unsupported platform: ${osType}`);
  }
}

// Audio Queue
class AudioQueue {
  private player: AudioPlayer;
  private queue: Array<{ path: string; volume?: number }> = [];
  private isProcessing = false;

  constructor() {
    this.player = createAudioPlayer();
  }

  async add(filePath: string, volume?: number): Promise<void> {
    this.queue.push({ path: filePath, volume });
    if (!this.isProcessing) {
      this.processQueue();
    }
  }

  async playAudioFromURL(url: string, volume?: number): Promise<void> {
    if (!url || url === 'undefined' || url === 'null') {
      throw new Error('Invalid audio URL');
    }
    
    try {
      const tempDir = os.tmpdir();
      const tempFile = path.join(tempDir, `cloudios-audio-${Date.now()}.wav`);
      
      const response = await fetch(url);
      if (!response.ok) {
        throw new Error(`Failed to download audio: ${response.status}`);
      }
      
      const buffer = await response.arrayBuffer();
      await fs.writeFile(tempFile, Buffer.from(buffer));
      
      await this.add(tempFile, volume);
      
      // Clean up temp file after playing
      setTimeout(async () => {
        try {
          await fs.unlink(tempFile);
        } catch {
          // Ignore cleanup errors
        }
      }, 5000);
    } catch (error) {
      throw error;
    }
  }

  private async processQueue(): Promise<void> {
    if (this.isProcessing || this.queue.length === 0) {
      return;
    }

    this.isProcessing = true;

    while (this.queue.length > 0) {
      const item = this.queue.shift()!;
      try {
        await this.player.play(item.path, item.volume);
      } catch (error) {
        console.error("Error playing audio:", error);
      }
    }

    this.isProcessing = false;
  }

  stop(): void {
    this.queue = [];
    this.player.stop();
    this.isProcessing = false;
  }

  get length(): number {
    return this.queue.length;
  }
}

// Main Hermes Class
class HermesAgent {
  private ui: TerminalUI;
  private eventSource?: EventSource;
  private audioQueue?: AudioQueue;
  private reconnectTimeout?: NodeJS.Timeout;
  private heartbeatInterval?: NodeJS.Timer;
  private config: {
    server: string;
    mute: boolean;
    volume: number;
  };

  constructor(config: any) {
    this.config = {
      server: config.server || DEFAULT_SERVER,
      mute: config.mute || false,
      volume: config.volume || 1.0,
    };
    
    const projectName = path.basename(process.cwd());
    this.ui = new TerminalUI(projectName, this.config.server);
  }

  async run() {
    // Initial render
    this.ui.render();
    
    if (!this.config.mute) {
      this.audioQueue = new AudioQueue();
    }
    
    this.ui.addLog('Starting CLOUDIOS audio stream...', 'info');
    
    // Connect to server
    this.connect();
    
    // Handle graceful shutdown
    const shutdown = async () => {
      this.ui.addLog('Shutting down...', 'warning');
      
      // Send disconnect signal
      try {
        await fetch(`${this.config.server}/api/cloudios-agent/disconnect`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            project: path.basename(process.cwd()),
            timestamp: new Date().toISOString()
          })
        });
      } catch (error) {
        // Ignore errors during shutdown
      }
      
      if (this.eventSource) {
        this.eventSource.close();
      }
      if (this.reconnectTimeout) {
        clearTimeout(this.reconnectTimeout);
      }
      if (this.heartbeatInterval) {
        clearInterval(this.heartbeatInterval);
      }
      
      this.ui.cleanup();
      process.exit(0);
    };
    
    process.on('SIGINT', shutdown);
    process.on('SIGTERM', shutdown);
    
    // Periodic stats update
    setInterval(() => {
      this.ui.updateStats({
        queueSize: this.audioQueue?.length || 0
      });
    }, 1000);
  }

  private connect() {
    const projectName = path.basename(process.cwd());
    const url = `${this.config.server}/api/audio.sse?project=${encodeURIComponent(projectName)}`;
    
    this.eventSource = new EventSource(url);
    
    this.eventSource.onopen = () => {
      this.ui.updateStats({ connected: true });
      this.ui.addLog('Connected to CLOUDIOS audio stream', 'success');
      
      // Start heartbeat
      this.startHeartbeat();
    };
    
    this.eventSource.onmessage = async (event) => {
      try {
        const data = JSON.parse(event.data);
        
        // Debug: Log all SSE events
        console.log('[SSE Event]', data.type, data);
        
        // Handle transcript sync request
        if (data.type === "transcript_sync_request") {
          console.log('[Transcript Sync] Received request:', data);
          await this.handleTranscriptSyncRequest(data);
          return;
        }
        
        if (data.type === "audio_ready" && data.message) {
          const message = data.message;
          
          // Filter by project/repo_name
          const projectName = path.basename(process.cwd());
          if (message.repo_name && message.repo_name !== projectName) {
            this.ui.updateStats({ audioFiltered: this.ui.stats.audioFiltered + 1 });
            return; // Skip messages from other projects
          }
          
          // Validate audio URL exists (check both audio_url and mp3_path for compatibility)
          const audioPath = message.audio_url || message.mp3_path;
          if (!audioPath) {
            this.ui.addLog('Received message without audio URL', 'warning');
            return;
          }
          
          const agentName = message.agent_name || 'Unknown';
          const summary = message.summary || 'Audio notification';
          
          this.ui.addLog(`Playing audio from ${agentName}: ${summary}`, 'info');
          
          try {
            const audioUrl = `${this.config.server}${audioPath}`;
            await this.audioQueue?.playAudioFromURL(audioUrl, this.config.volume);
            this.ui.updateStats({ audioPlayed: this.ui.stats.audioPlayed + 1 });
          } catch (error: any) {
            this.ui.addLog(`Failed to play audio: ${error.message}`, 'error');
            this.ui.updateStats({ errors: this.ui.stats.errors + 1 });
          }
        }
      } catch (error: any) {
        this.ui.addLog(`Error processing message: ${error.message}`, 'error');
        this.ui.updateStats({ errors: this.ui.stats.errors + 1 });
      }
    };
    
    this.eventSource.onerror = (error) => {
      this.ui.updateStats({ connected: false });
      this.ui.addLog('Connection lost. Reconnecting in 5 seconds...', 'error');
      
      // Stop heartbeat
      if (this.heartbeatInterval) {
        clearInterval(this.heartbeatInterval);
        this.heartbeatInterval = undefined;
      }
      
      if (this.reconnectTimeout) {
        clearTimeout(this.reconnectTimeout);
      }
      
      this.reconnectTimeout = setTimeout(() => {
        this.ui.addLog('Attempting to reconnect...', 'info');
        this.connect();
      }, 5000);
    };
  }

  private async handleTranscriptSyncRequest(data: any) {
    const { request_id, target_agent, session_id, transcript_path, destination_path } = data;
    const projectName = path.basename(process.cwd());
    
    // Only handle if this is the target agent
    if (target_agent !== projectName && !transcript_path?.includes(projectName)) {
      return;
    }
    
    this.ui.addLog('Received transcript sync request', 'info');
    
    try {
      // Check if transcript file exists
      if (!existsSync(transcript_path)) {
        this.ui.addLog(`Transcript file not found: ${transcript_path}`, 'error');
        await this.sendTranscriptSyncResponse(request_id, false, 'Transcript file not found');
        return;
      }
      
      // Read the transcript file
      const transcriptContent = await fs.readFile(transcript_path, 'utf-8');
      
      // Upload to server
      const formData = new FormData();
      const blob = new Blob([transcriptContent], { type: 'application/x-ndjson' });
      formData.append('file', blob, path.basename(transcript_path));
      formData.append('request_id', request_id);
      formData.append('session_id', session_id || target_agent);
      
      const response = await fetch(`${this.config.server}/api/transcript-upload`, {
        method: 'POST',
        body: formData
      });
      
      if (response.ok) {
        this.ui.addLog('Transcript uploaded successfully', 'success');
        await this.sendTranscriptSyncResponse(request_id, true, 'Transcript uploaded successfully');
      } else {
        const error = await response.text();
        this.ui.addLog(`Failed to upload transcript: ${error}`, 'error');
        await this.sendTranscriptSyncResponse(request_id, false, `Upload failed: ${error}`);
      }
    } catch (error: any) {
      this.ui.addLog(`Error syncing transcript: ${error.message}`, 'error');
      await this.sendTranscriptSyncResponse(request_id, false, error.message);
    }
  }
  
  private async sendTranscriptSyncResponse(requestId: string, success: boolean, message: string) {
    try {
      await fetch(`${this.config.server}/api/transcript-sync-response`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          request_id: requestId,
          success,
          message,
          timestamp: new Date().toISOString()
        })
      });
    } catch (error) {
      // Ignore errors when sending response
    }
  }

  private startHeartbeat() {
    const projectName = path.basename(process.cwd());
    
    // Clear any existing heartbeat
    if (this.heartbeatInterval) {
      clearInterval(this.heartbeatInterval);
    }
    
    // Heartbeat function
    const sendHeartbeat = async () => {
      try {
        const response = await fetch(`${this.config.server}/api/cloudios-agent/heartbeat`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            project: projectName,
            timestamp: new Date().toISOString(),
            stats: {
              audioPlayed: this.ui.stats.audioPlayed,
              audioFiltered: this.ui.stats.audioFiltered,
              connected: this.ui.stats.connected
            }
          })
        });
        
        if (!response.ok) {
          this.ui.addLog(`Heartbeat failed: ${response.status}`, 'warning');
        } else {
          this.ui.updateStats({ lastHeartbeat: new Date() });
        }
      } catch (error: any) {
        this.ui.addLog(`Heartbeat error: ${error.message}`, 'error');
      }
    };
    
    // Send initial heartbeat
    setTimeout(sendHeartbeat, 1000);
    
    // Send heartbeat every 30 seconds
    this.heartbeatInterval = setInterval(sendHeartbeat, 30000);
  }
}

// Main entry point
async function main() {
  const { values, positionals } = parseArgs({
    args: Bun.argv,
    options: {
      server: {
        type: 'string',
        short: 's',
        default: DEFAULT_SERVER,
      },
      mute: {
        type: 'boolean',
        short: 'm',
        default: false,
      },
      volume: {
        type: 'string',
        short: 'v',
        default: '100',
      },
      help: {
        type: 'boolean',
        short: 'h',
        default: false,
      },
    },
    strict: false,
    allowPositionals: true,
  });

  if (values.help) {
    console.log(`
Hermes - CLOUDIOS Audio Streaming Agent

Usage: hermes [options]

Options:
  -s, --server <url>    CLOUDIOS server URL (default: ${DEFAULT_SERVER})
  -m, --mute           Mute audio playback
  -v, --volume <0-100> Set volume percentage (default: 100)
  -h, --help           Show this help message

Examples:
  hermes                      # Connect to local server
  hermes -s http://remote:4000  # Connect to remote server
  hermes -v 50                # Play at 50% volume
`);
    process.exit(0);
  }

  const config = {
    server: values.server,
    mute: values.mute,
    volume: parseInt(values.volume as string) / 100,
  };

  const agent = new HermesAgent(config);
  await agent.run();
}

// Run the agent
main().catch(error => {
  console.error('Fatal error:', error);
  process.exit(1);
});