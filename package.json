{
  "name": "@moneyworks/monorepo",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "bun-types": "latest",
    "xml2js": "^0.6.2"
  },
  "private": true,
  "scripts": {
    "build:cli": "bun --cwd packages/cli build",
    "build:mcp": "bun --cwd packages/mcp-server build",
    "clean": "rm -rf node_modules packages/*/node_modules",
    "test": "bun test",
    "cli": "bun --cwd packages/api cli",
    "mw": "bun --cwd packages/cli dev",
    "mcp": "bun --cwd packages/mcp-server dev",
    "mcp:build": "bun --cwd packages/mcp-server build",
    "mcp:start": "bun --cwd packages/mcp-server start",
    "api": "bun --cwd packages/api dev",
    "api:start": "bun --cwd packages/api start",
    "api:build": "bun --cwd packages/api build",
    "web": "bun --bun --cwd packages/web1 dev",
    "web:build": "bun --cwd packages/web1 build"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ]
}