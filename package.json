{
  "name": "mw-core",
  "version": "1.0.50",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "bun run --watch src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "build2": "bun build \\\n\t--compile \\\n\t--minify-whitespace \\\n\t--minify-syntax \\\n\t--target bun \\\n\t--outfile server \\\n\t./src/index.ts",
    "start": "bun ./dist/index.js",
    "cli": "bun src/cli/mw-cli.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/swagger": "^1.2.2",
    "@modelcontextprotocol/sdk": "^1.7.0",
    "@smithery/sdk": "^1.0.2",
    "@types/xml2js": "^0.4.14",
    "@zod/mini": "^4.0.0-beta.0",
    "axios": "^1.6.8",
    "commander": "^13.1.0",
    "elysia": "latest",
    "fast-xml-parser": "^4.3.6",
    "jsdom": "^26.0.0",
    "translate": "^3.0.1",
    "xml2js": "^0.6.2",
    "zod": "^4.0.0-beta.20250415T232143"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "bun-types": "latest"
  },
  "module": "src/index.js",
  "bin": {
    "mw-cli": "./src/cli/mw-cli.ts"
  }
