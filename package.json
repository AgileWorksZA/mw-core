{
  "name": "@moneyworks/monorepo",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "bun-types": "latest"
  },
  "private": true,
  "scripts": {
    "dev": "bun run dev:api",
    "dev:api": "bun --cwd packages/api dev",
    "dev:mcp": "bun --cwd packages/mcp-server dev",
    "build": "bun run build:api && bun run build:mcp",
    "build:api": "bun --cwd packages/api build",
    "build:mcp": "bun --cwd packages/mcp-server build",
    "clean": "rm -rf node_modules packages/*/node_modules",
    "test": "bun test",
    "cli": "bun --cwd packages/api cli"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ]
}